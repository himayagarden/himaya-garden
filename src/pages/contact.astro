---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
    title="Contact — Himaya Garden"
    description="Get in touch with Himaya Garden. Schedule a tour, inquire about events, or reach out to our team in Tucson, Arizona."
>
    <main>
        <!-- Page Header -->
        <section class="pt-32 pb-20 bg-cream">
            <div class="max-w-6xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32 text-center">
                <p class="section-label fade-in">Get In Touch</p>
                <h1 class="fade-in delay-1 font-serif text-4xl md:text-6xl lg:text-7xl font-medium tracking-tight leading-tight text-charcoal mb-6">
                    Contact Us
                </h1>
                <p class="fade-in delay-2 text-lg text-stone leading-relaxed max-w-2xl mx-auto">
                    We'd love to hear from you. Whether you're planning a celebration or just want to learn more about Himaya Garden, our team is here
                    to help.
                </p>
            </div>
        </section>

        <!-- Contact Info Cards -->
        <section class="py-24 bg-cream">
            <div class="max-w-6xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
                    <!-- Phone -->
                    <a
                        href="tel:+15204671033"
                        class="group bg-white rounded-2xl p-8 shadow-sm border border-stone/10 text-center hover:-translate-y-1 hover:shadow-md transition-all"
                    >
                        <div
                            class="w-14 h-14 mx-auto mb-5 rounded-full bg-sage/10 flex items-center justify-center text-sage group-hover:bg-sage group-hover:text-white transition-all"
                        >
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                >
                                </path>
                            </svg>
                        </div>
                        <h3 class="font-serif text-xl text-charcoal mb-2">Call Us</h3>
                        <p class="text-stone text-sm mb-3">Speak directly with our team</p>
                        <p class="text-sage font-medium">(520) 467-1033</p>
                    </a>

                    <!-- Email -->
                    <a
                        href="mailto:hello@himayagarden.com"
                        class="group bg-white rounded-2xl p-8 shadow-sm border border-stone/10 text-center hover:-translate-y-1 hover:shadow-md transition-all"
                    >
                        <div
                            class="w-14 h-14 mx-auto mb-5 rounded-full bg-sage/10 flex items-center justify-center text-sage group-hover:bg-sage group-hover:text-white transition-all"
                        >
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                >
                                </path>
                            </svg>
                        </div>
                        <h3 class="font-serif text-xl text-charcoal mb-2">Email Us</h3>
                        <p class="text-stone text-sm mb-3">We'll respond within 24–48 hours</p>
                        <p class="text-sage font-medium">hello@himayagarden.com</p>
                    </a>

                    <!-- Location -->
                    <a
                        href="https://www.google.com/maps/search/?api=1&query=Himaya+Garden+Tucson+AZ"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="group bg-white rounded-2xl p-8 shadow-sm border border-stone/10 text-center hover:-translate-y-1 hover:shadow-md transition-all"
                    >
                        <div
                            class="w-14 h-14 mx-auto mb-5 rounded-full bg-sage/10 flex items-center justify-center text-sage group-hover:bg-sage group-hover:text-white transition-all"
                        >
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                >
                                </path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                        </div>
                        <h3 class="font-serif text-xl text-charcoal mb-2">Visit Us</h3>
                        <p class="text-stone text-sm mb-3">Tucson, Arizona</p>
                        <p class="text-sage font-medium">Get Directions</p>
                    </a>
                </div>
            </div>
        </section>

        <!-- Quick Links -->
        <section class="py-24 bg-cream-warm">
            <div class="max-w-6xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="text-center mb-16">
                    <h2 class="font-serif text-3xl md:text-4xl text-charcoal mb-4">How Can We Help?</h2>
                    <div class="w-20 h-0.5 bg-sage mx-auto"></div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto">
                    <a
                        href="/venue-rates"
                        class="group flex items-center gap-5 bg-white rounded-xl p-6 shadow-sm border border-stone/10 hover:-translate-y-1 hover:shadow-md transition-all"
                    >
                        <div
                            class="w-12 h-12 rounded-lg bg-sage/10 flex items-center justify-center text-sage group-hover:bg-sage group-hover:text-white transition-all shrink-0"
                        >
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"
                                >
                                </path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-serif text-lg text-charcoal group-hover:text-sage transition-colors">View Venue Details</h3>
                            <p class="text-stone text-sm">Explore our venue rates and collections</p>
                        </div>
                    </a>

                    <a
                        href="/gallery"
                        class="group flex items-center gap-5 bg-white rounded-xl p-6 shadow-sm border border-stone/10 hover:-translate-y-1 hover:shadow-md transition-all"
                    >
                        <div
                            class="w-12 h-12 rounded-lg bg-sage/10 flex items-center justify-center text-sage group-hover:bg-sage group-hover:text-white transition-all shrink-0"
                        >
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                                >
                                </path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-serif text-lg text-charcoal group-hover:text-sage transition-colors">See the Gallery</h3>
                            <p class="text-stone text-sm">Browse photos of our garden and tea house</p>
                        </div>
                    </a>

                    <a
                        href="/rental-inquiry"
                        class="group flex items-center gap-5 bg-white rounded-xl p-6 shadow-sm border border-stone/10 hover:-translate-y-1 hover:shadow-md transition-all"
                    >
                        <div
                            class="w-12 h-12 rounded-lg bg-sage/10 flex items-center justify-center text-sage group-hover:bg-sage group-hover:text-white transition-all shrink-0"
                        >
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                                >
                                </path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-serif text-lg text-charcoal group-hover:text-sage transition-colors">Submit an Inquiry</h3>
                            <p class="text-stone text-sm">Start planning your event with us</p>
                        </div>
                    </a>

                    <a
                        href="/about-us"
                        class="group flex items-center gap-5 bg-white rounded-xl p-6 shadow-sm border border-stone/10 hover:-translate-y-1 hover:shadow-md transition-all"
                    >
                        <div
                            class="w-12 h-12 rounded-lg bg-sage/10 flex items-center justify-center text-sage group-hover:bg-sage group-hover:text-white transition-all shrink-0"
                        >
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
                                >
                                </path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-serif text-lg text-charcoal group-hover:text-sage transition-colors">About Our Story</h3>
                            <p class="text-stone text-sm">Learn about Himaya Garden's heritage</p>
                        </div>
                    </a>
                </div>
            </div>
        </section>

        <!-- Hours -->
        <section class="py-24 bg-cream">
            <div class="max-w-4xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32 text-center">
                <h2 class="font-serif text-3xl md:text-4xl text-charcoal mb-8">Visit by Appointment</h2>
                <p class="text-stone text-lg leading-relaxed max-w-2xl mx-auto mb-8">
                    We welcome tours and visits by scheduled appointment. Reach out to find a time that works for you.
                </p>
                <div class="bg-sage/5 rounded-2xl p-8 border border-sage/20 inline-block">
                    <p class="text-charcoal font-medium mb-2">Tours Available</p>
                    <p class="text-stone">Monday – Saturday</p>
                    <p class="text-stone">By appointment only</p>
                </div>
            </div>
        </section>

        <!-- Final CTA -->
        <section class="relative py-32 text-center text-white overflow-hidden">
            <div class="absolute inset-0 z-0">
                <img src="/img/AG1_4.jpg" alt="Himaya Garden at golden hour" class="w-full h-full object-cover" />
            </div>
            <div class="absolute inset-0 bg-charcoal/50 z-[1]"></div>
            <div class="relative z-[2] max-w-3xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <h2 class="fade-in font-serif text-4xl md:text-6xl font-medium tracking-tight leading-tight mb-6">Let's Connect</h2>
                <p class="fade-in delay-1 text-lg leading-relaxed mb-8 text-white/90">
                    Every great celebration starts with a conversation. We can't wait to hear from you.
                </p>
                <div class="fade-in delay-2 flex flex-wrap gap-4 justify-center">
                    <a href="tel:+15204671033" class="btn-primary bg-white text-charcoal hover:bg-charcoal hover:text-white transition-all">
                        Call (520) 467-1033
                    </a>
                    <a href="/rental-inquiry" class="btn-secondary border-white/30 text-white hover:bg-white hover:text-charcoal transition-all">
                        Submit an Inquiry
                    </a>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>
