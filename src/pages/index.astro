---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Himaya Garden — A Desert Sanctuary for Meaningful Gatherings">
    <main>
        <!-- Hero -->
        <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-cream-warm">
            <div class="absolute inset-0 z-0 opacity-85">
                <img
                    src="media/img/hero-image.webp"
                    alt="Himaya Garden wedding ceremony"
                    class="w-full h-full object-cover brightness-115 saturate-90"
                />
            </div>
            <div class="absolute inset-0 z-[1] bg-cream/55"></div>
            <div class="absolute inset-0 z-[2] bg-gradient-to-b from-cream/30 to-cream/70"></div>
            <div class="relative z-[3] text-center text-charcoal max-w-3xl pt-[120px] pb-[120px] px-6 md:px-12 lg:px-20 xl:px-32">
                <p class="fade-in delay-1 text-sm tracking-[0.3em] uppercase mb-6 text-sage-dark">Joyful Gathering and Events</p>
                <h1 class="fade-in delay-2 font-serif text-5xl md:text-7xl lg:text-[5.5rem] font-light leading-tight mb-6">
                    A Desert Sanctuary for<br />Meaningful Gatherings
                </h1>
                <p class="fade-in delay-3 text-lg leading-relaxed max-w-xl mx-auto mb-8 text-stone">
                    There is a moment just before sunset in Tucson when the desert softens. The light turns golden. The air cools. Conversations slow.
                    At Himaya Garden, that moment becomes the setting for your celebration.
                </p>
                <div class="fade-in delay-4 flex flex-wrap gap-4 justify-center mb-8">
                    <a href="/contact" class="btn-primary">Book a Private Tour</a>
                    <a href="/about-us" class="btn-secondary">Our Story</a>
                </div>
                <div class="fade-in delay-5">
                    <a href="tel:+15201234567" class="inline-flex items-center gap-2 text-stone text-sm transition-colors hover:text-charcoal">
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="w-[18px] h-[18px]"
                        >
                            <path
                                d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"
                            >
                            </path>
                        </svg>
                        Prefer to call? (520) 123-4567
                    </a>
                </div>
            </div>
            <div class="absolute bottom-8 left-1/2 z-[3] animate-bounce-slow -translate-x-1/2">
                <div class="w-6 h-10 border-2 border-charcoal/30 rounded-xl relative flex justify-center pt-2">
                    <div class="w-1 h-2 bg-charcoal/40 rounded-sm"></div>
                </div>
            </div>
        </section>

        <!-- Email Capture -->
        <section class="bg-sage text-white py-12">
            <div class="flex flex-col gap-6 items-center text-center md:flex-row md:justify-between md:text-left px-6 md:px-12 lg:px-20 xl:px-32">
                <p class="text-lg max-w-lg">
                    <strong>Join the Garden Journal</strong> — Be the first to know about open dates, seasonal menus, and hidden gatherings.
                </p>
                <form class="flex gap-2 w-full max-w-md" onsubmit="event.preventDefault(); window.location.href='/contact';">
                    <input
                        type="email"
                        placeholder="Your email address"
                        required
                        class="flex-1 px-5 py-3.5 border border-white/30 bg-white/10 text-white rounded-sm font-sans text-sm placeholder:text-white/60 focus:outline-none focus:border-white/60 focus:bg-white/15"
                    />
                    <button
                        type="submit"
                        class="px-6 py-3.5 bg-white text-sage border-none rounded-sm font-medium text-sm tracking-widest uppercase cursor-pointer transition-all whitespace-nowrap hover:bg-cream"
                    >
                        Join!
                    </button>
                </form>
            </div>
        </section>

        <!-- Marquee -->
        <div class="bg-charcoal text-white py-6 overflow-hidden whitespace-nowrap">
            <div class="inline-flex animate-marquee">
                <span class="inline-flex items-center gap-6 px-6 text-sm tracking-[0.2em] uppercase text-white/80">
                    Weddings <span class="w-1.5 h-1.5 bg-gold rounded-full inline-block"></span>
                </span>
                <span class="inline-flex items-center gap-6 px-6 text-sm tracking-[0.2em] uppercase text-white/80">
                    Retreats <span class="w-1.5 h-1.5 bg-gold rounded-full inline-block"></span>
                </span>
                <span class="inline-flex items-center gap-6 px-6 text-sm tracking-[0.2em] uppercase text-white/80">
                    Private Celebrations <span class="w-1.5 h-1.5 bg-gold rounded-full inline-block"></span>
                </span>
                <span class="inline-flex items-center gap-6 px-6 text-sm tracking-[0.2em] uppercase text-white/80">
                    Workshops <span class="w-1.5 h-1.5 bg-gold rounded-full inline-block"></span>
                </span>
                <span class="inline-flex items-center gap-6 px-6 text-sm tracking-[0.2em] uppercase text-white/80">
                    High Tea <span class="w-1.5 h-1.5 bg-gold rounded-full inline-block"></span>
                </span>
                <span class="inline-flex items-center gap-6 px-6 text-sm tracking-[0.2em] uppercase text-white/80">
                    Garden Tours <span class="w-1.5 h-1.5 bg-gold rounded-full inline-block"></span>
                </span>
                <span class="inline-flex items-center gap-6 px-6 text-sm tracking-[0.2em] uppercase text-white/80">
                    Sunset Ceremonies <span class="w-1.5 h-1.5 bg-gold rounded-full inline-block"></span>
                </span>
                <span class="inline-flex items-center gap-6 px-6 text-sm tracking-[0.2em] uppercase text-white/80">
                    Filipino Heritage Dining <span class="w-1.5 h-1.5 bg-gold rounded-full inline-block"></span>
                </span>
                <span class="inline-flex items-center gap-6 px-6 text-sm tracking-[0.2em] uppercase text-white/80">
                    Weddings <span class="w-1.5 h-1.5 bg-gold rounded-full inline-block"></span>
                </span>
                <span class="inline-flex items-center gap-6 px-6 text-sm tracking-[0.2em] uppercase text-white/80">
                    Retreats <span class="w-1.5 h-1.5 bg-gold rounded-full inline-block"></span>
                </span>
                <span class="inline-flex items-center gap-6 px-6 text-sm tracking-[0.2em] uppercase text-white/80">
                    Private Celebrations <span class="w-1.5 h-1.5 bg-gold rounded-full inline-block"></span>
                </span>
                <span class="inline-flex items-center gap-6 px-6 text-sm tracking-[0.2em] uppercase text-white/80">
                    Workshops <span class="w-1.5 h-1.5 bg-gold rounded-full inline-block"></span>
                </span>
                <span class="inline-flex items-center gap-6 px-6 text-sm tracking-[0.2em] uppercase text-white/80">
                    High Tea <span class="w-1.5 h-1.5 bg-gold rounded-full inline-block"></span>
                </span>
                <span class="inline-flex items-center gap-6 px-6 text-sm tracking-[0.2em] uppercase text-white/80">
                    Garden Tours <span class="w-1.5 h-1.5 bg-gold rounded-full inline-block"></span>
                </span>
                <span class="inline-flex items-center gap-6 px-6 text-sm tracking-[0.2em] uppercase text-white/80">
                    Sunset Ceremonies <span class="w-1.5 h-1.5 bg-gold rounded-full inline-block"></span>
                </span>
                <span class="inline-flex items-center gap-6 px-6 text-sm tracking-[0.2em] uppercase text-white/80">
                    Filipino Heritage Dining <span class="w-1.5 h-1.5 bg-gold rounded-full inline-block"></span>
                </span>
            </div>
        </div>

        <!-- Intro -->
        <section class="py-24 text-center bg-cream">
            <div class="max-w-2xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <p class="section-label fade-in">A Garden Sanctuary</p>
                <h2 class="fade-in delay-1 font-serif text-4xl md:text-6xl font-medium tracking-tight leading-tight mb-6 text-charcoal">
                    For Celebration, Connection,<br />and Belonging
                </h2>
                <p class="fade-in delay-2 text-lg text-stone leading-relaxed">
                    Whether you're planning a wedding, retreat, private celebration, or immersive workshop, Himaya Garden offers an experience your
                    guests will feel long after they leave.
                </p>
            </div>
        </section>

        <!-- Stats -->
        <section class="bg-warm-white py-16">
            <div class="max-w-4xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
                    <div class="fade-in">
                        <div class="font-serif text-5xl font-light text-sage leading-none mb-2">25+</div>
                        <div class="text-sm tracking-[0.15em] uppercase text-stone">Years of Hospitality</div>
                    </div>
                    <div class="fade-in delay-1">
                        <div class="font-serif text-5xl font-light text-sage leading-none mb-2">500+</div>
                        <div class="text-sm tracking-[0.15em] uppercase text-stone">Events Hosted</div>
                    </div>
                    <div class="fade-in delay-2">
                        <div class="font-serif text-5xl font-light text-sage leading-none mb-2">3</div>
                        <div class="text-sm tracking-[0.15em] uppercase text-stone">Generations of Recipes</div>
                    </div>
                    <div class="fade-in delay-3">
                        <div class="font-serif text-5xl font-light text-sage leading-none mb-2">1</div>
                        <div class="text-sm tracking-[0.15em] uppercase text-stone">Desert Sanctuary</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Events Hover -->
        <section class="py-24 bg-cream">
            <div class="max-w-6xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="text-center mb-12">
                    <p class="section-label fade-in">Gatherings</p>
                    <h2 class="fade-in delay-1 font-serif text-4xl md:text-6xl font-medium tracking-tight leading-tight text-charcoal">
                        Designed for Atmosphere, Not Excess
                    </h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
                    <div class="fade-in relative rounded overflow-hidden aspect-[4/3] cursor-pointer group">
                        <img
                            src="/media/img/wedding-venue.webp"
                            alt="Weddings"
                            class="w-full h-full object-cover transition-transform duration-[800ms] ease-out group-hover:scale-105"
                        />
                        <div
                            class="absolute inset-0 bg-gradient-to-t from-charcoal/85 via-charcoal/20 to-transparent flex flex-col justify-end p-8 text-white transition-colors duration-[400ms]"
                        >
                            <h3 class="font-serif text-3xl mb-2 font-normal">Weddings</h3>
                            <div
                                class="max-h-0 overflow-hidden opacity-0 transition-all duration-500 ease-out group-hover:max-h-[200px] group-hover:opacity-100"
                            >
                                <p class="text-sm leading-relaxed mb-4 text-white/90">
                                    Sunset ceremonies, receptions for up to 120, and heritage-inspired menus that make your day unforgettable.
                                </p>
                                <a
                                    href="/contact"
                                    class="inline-flex items-center gap-2 text-sm tracking-[0.15em] uppercase text-gold transition-colors duration-300 hover:text-white group/link"
                                >
                                    Inquire
                                    <svg
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        class="w-4 h-4 transition-transform duration-300 group-hover/link:translate-x-1"
                                    >
                                        <path d="M5 12h14M12 5l7 7-7 7"></path>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="fade-in delay-1 relative rounded overflow-hidden aspect-[4/3] cursor-pointer group">
                        <img
                            src="/media/img/wellness-img.png"
                            alt="Retreats"
                            class="w-full h-full object-cover transition-transform duration-[800ms] ease-out group-hover:scale-105"
                        />
                        <div
                            class="absolute inset-0 bg-gradient-to-t from-charcoal/85 via-charcoal/20 to-transparent flex flex-col justify-end p-8 text-white transition-colors duration-[400ms]"
                        >
                            <h3 class="font-serif text-3xl mb-2 font-normal">Retreats</h3>
                            <div
                                class="max-h-0 overflow-hidden opacity-0 transition-all duration-500 ease-out group-hover:max-h-[200px] group-hover:opacity-100"
                            >
                                <p class="text-sm leading-relaxed mb-4 text-white/90">
                                    Wellness weekends, team offsites, and creative workshops in a space designed for stillness and focus.
                                </p>
                                <a
                                    href="/contact"
                                    class="inline-flex items-center gap-2 text-sm tracking-[0.15em] uppercase text-gold transition-colors duration-300 hover:text-white group/link"
                                >
                                    Inquire
                                    <svg
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        class="w-4 h-4 transition-transform duration-300 group-hover/link:translate-x-1"
                                    >
                                        <path d="M5 12h14M12 5l7 7-7 7"></path>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="fade-in delay-2 relative rounded overflow-hidden aspect-[4/3] cursor-pointer group">
                        <img
                            src="/media/img/private-celebration.jpg"
                            alt="Private Celebrations"
                            class="w-full h-full object-cover transition-transform duration-[800ms] ease-out group-hover:scale-105"
                        />
                        <div
                            class="absolute inset-0 bg-gradient-to-t from-charcoal/85 via-charcoal/20 to-transparent flex flex-col justify-end p-8 text-white transition-colors duration-[400ms]"
                        >
                            <h3 class="font-serif text-3xl mb-2 font-normal">Private Celebrations</h3>
                            <div
                                class="max-h-0 overflow-hidden opacity-0 transition-all duration-500 ease-out group-hover:max-h-[200px] group-hover:opacity-100"
                            >
                                <p class="text-sm leading-relaxed mb-4 text-white/90">
                                    Milestones, reunions, and anniversaries in a hidden sanctuary built for connection over crowds.
                                </p>
                                <a
                                    href="/contact"
                                    class="inline-flex items-center gap-2 text-sm tracking-[0.15em] uppercase text-gold transition-colors duration-300 hover:text-white group/link"
                                >
                                    Inquire
                                    <svg
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        class="w-4 h-4 transition-transform duration-300 group-hover/link:translate-x-1"
                                    >
                                        <path d="M5 12h14M12 5l7 7-7 7"></path>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="fade-in delay-3 relative rounded overflow-hidden aspect-[4/3] cursor-pointer group">
                        <img
                            src="/media/img/workshop.webp"
                            alt="Workshops"
                            class="w-full h-full object-cover transition-transform duration-[800ms] ease-out group-hover:scale-105"
                        />
                        <div
                            class="absolute inset-0 bg-gradient-to-t from-charcoal/85 via-charcoal/20 to-transparent flex flex-col justify-end p-8 text-white transition-colors duration-[400ms]"
                        >
                            <h3 class="font-serif text-3xl mb-2 font-normal">Workshops</h3>
                            <div
                                class="max-h-0 overflow-hidden opacity-0 transition-all duration-500 ease-out group-hover:max-h-[200px] group-hover:opacity-100"
                            >
                                <p class="text-sm leading-relaxed mb-4 text-white/90">
                                    Cooking classes, art sessions, and cultural programming in a garden that inspires creation.
                                </p>
                                <a
                                    href="/contact"
                                    class="inline-flex items-center gap-2 text-sm tracking-[0.15em] uppercase text-gold transition-colors duration-300 hover:text-white group/link"
                                >
                                    Inquire
                                    <svg
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        class="w-4 h-4 transition-transform duration-300 group-hover/link:translate-x-1"
                                    >
                                        <path d="M5 12h14M12 5l7 7-7 7"></path>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="text-center fade-in">
                    <a href="/contact" class="btn-primary">Book a Private Tour</a>
                </div>
            </div>
        </section>

        <!-- High Tea -->
        <section class="py-24 bg-cream-warm">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center max-w-6xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div>
                    <p class="section-label fade-in">Our Signature Experience</p>
                    <h2 class="fade-in delay-1 font-serif text-4xl md:text-6xl font-medium tracking-tight leading-tight mb-6 text-charcoal">
                        High Tea in the Garden
                    </h2>
                    <div class="fade-in delay-2">
                        <p class="text-lg text-stone mb-4 leading-relaxed">
                            Our most requested gathering. An afternoon of delicate pastries, heritage-inspired finger foods, and botanical teas served
                            among the blooms.
                        </p>
                        <p class="text-stone leading-relaxed mb-6">
                            Rooted in the tradition of Filipino merienda and reimagined through three generations of bakers, our High Tea is more than
                            a meal — it is a slowing down. A remembering. A celebration of the sweet and savory moments that connect us.
                        </p>
                        <ul class="list-none p-0 m-0 mb-8">
                            <li class="flex items-start gap-3 py-3 text-stone text-sm border-b border-charcoal/5">
                                <span class="text-sage text-xs leading-6">◈</span> Seasonal menu crafted by Odette & Milana
                            </li>
                            <li class="flex items-start gap-3 py-3 text-stone text-sm border-b border-charcoal/5">
                                <span class="text-sage text-xs leading-6">◈</span> Garden seating for up to 24 guests
                            </li>
                            <li class="flex items-start gap-3 py-3 text-stone text-sm border-b border-charcoal/5">
                                <span class="text-sage text-xs leading-6">◈</span> Perfect for bridal showers, birthdays, or simply because
                            </li>
                            <li class="flex items-start gap-3 py-3 text-stone text-sm border-b border-charcoal/5">
                                <span class="text-sage text-xs leading-6">◈</span> Available Saturday & Sunday afternoons
                            </li>
                        </ul>
                    </div>
                    <div class="fade-in delay-3 flex flex-wrap gap-4 items-center">
                        <a href="/contact" class="btn-primary">Reserve High Tea</a>
                        <a href="/events" class="btn-secondary">View All Events</a>
                    </div>
                </div>
                <div class="fade-in delay-2">
                    <img src="/media/img/tea-circles.webp" alt="High Tea at Himaya Garden" class="w-full h-auto rounded" />
                </div>
            </div>
        </section>

        <!-- Features -->
        <section class="py-24 bg-cream">
            <div class="max-w-6xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="text-center mb-16 max-w-2xl mx-auto">
                    <p class="section-label fade-in">A Botanical Sanctuary in the Heart of Tucson</p>
                    <h2 class="fade-in delay-1 font-serif text-4xl md:text-5xl font-medium tracking-tight leading-tight text-charcoal">
                        Step into lush greenery, desert blooms, and intimate gathering spaces
                    </h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                    <div
                        class="fade-in text-center p-10 bg-warm-white rounded transition-all duration-[400ms] ease-out hover:-translate-y-1 hover:shadow-[0_20px_40px_rgba(45,45,45,0.06)]"
                    >
                        <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-sage/10 text-sage mb-6">
                            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M24 4C24 4 12 12 12 24C12 32 17 40 24 44C31 40 36 32 36 24C36 12 24 4 24 4Z"></path>
                                <path d="M24 14V34"></path>
                                <path d="M18 20C18 20 21 18 24 18C27 18 30 20 30 20"></path>
                                <path d="M18 28C18 28 21 26 24 26C27 26 30 28 30 28"></path>
                            </svg>
                        </div>
                        <h3 class="font-serif text-xl mb-4 font-normal text-charcoal">Private garden venue with layered outdoor spaces</h3>
                        <p class="text-sm text-stone leading-relaxed">
                            Lush greenery, curated garden paths, and intimate gathering spaces designed for beauty and flow.
                        </p>
                    </div>
                    <div
                        class="fade-in delay-1 text-center p-10 bg-warm-white rounded transition-all duration-[400ms] ease-out hover:-translate-y-1 hover:shadow-[0_20px_40px_rgba(45,45,45,0.06)]"
                    >
                        <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-sage/10 text-sage mb-6">
                            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                                <circle cx="24" cy="24" r="8"></circle>
                                <path d="M24 8V16"></path>
                                <path d="M24 32V40"></path>
                                <path d="M8 24H16"></path>
                                <path d="M32 24H40"></path>
                                <path d="M12.7 12.7L18.3 18.3"></path>
                                <path d="M29.7 29.7L35.3 35.3"></path>
                                <path d="M12.7 35.3L18.3 29.7"></path>
                                <path d="M29.7 18.3L35.3 12.7"></path>
                            </svg>
                        </div>
                        <h3 class="font-serif text-xl mb-4 font-normal text-charcoal">Desert-meets-botanical aesthetic</h3>
                        <p class="text-sm text-stone leading-relaxed">
                            Where desert resilience meets botanical care — strength and softness in harmony.
                        </p>
                    </div>
                    <div
                        class="fade-in delay-2 text-center p-10 bg-warm-white rounded transition-all duration-[400ms] ease-out hover:-translate-y-1 hover:shadow-[0_20px_40px_rgba(45,45,45,0.06)]"
                    >
                        <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-sage/10 text-sage mb-6">
                            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                                <rect x="8" y="12" width="32" height="24" rx="2"></rect>
                                <circle cx="24" cy="24" r="6"></circle>
                                <path d="M8 20L16 14L24 20"></path>
                                <path d="M32 26L40 20L40 32"></path>
                            </svg>
                        </div>
                        <h3 class="font-serif text-xl mb-4 font-normal text-charcoal">Naturally photogenic at every angle</h3>
                        <p class="text-sm text-stone leading-relaxed">The garden already tells a story. Your event doesn't need to be "styled."</p>
                    </div>
                    <div
                        class="fade-in delay-3 text-center p-10 bg-warm-white rounded transition-all duration-[400ms] ease-out hover:-translate-y-1 hover:shadow-[0_20px_40px_rgba(45,45,45,0.06)]"
                    >
                        <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-sage/10 text-sage mb-6">
                            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M4 36H44"></path>
                                <path d="M8 32C8 32 16 24 24 24C32 24 40 32 40 32"></path>
                                <circle cx="24" cy="16" r="6"></circle>
                                <path d="M12 12L16 16"></path>
                                <path d="M36 12L32 16"></path>
                                <path d="M24 6V10"></path>
                            </svg>
