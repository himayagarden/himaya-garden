---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<style>
    h1 {
        font-family: 'Inter', sans-serif, serif !important;
    }
</style>
<BaseLayout title="Himaya Garden — A Desert Sanctuary for Meaningful Gatherings">
    <main>
        <!-- Hero -->
        <section class="relative min-h-screen flex flex-col justify-between overflow-hidden pt-34 md:pt-40 pb-24 md:pb-32">
            <div class="absolute inset-0 z-0">
                <img src="media/img/hero-image.webp" alt="Himaya Garden wedding ceremony" class="w-full h-full object-cover" />
            </div>
            <div class="absolute inset-0 z-[1] bg-charcoal/30"></div>
            <div class="absolute inset-0 z-[2] bg-gradient-to-b from-transparent via-transparent to-cream/40"></div>

            <!-- Top: Headline -->
            <div class="relative z-[3] text-center text-white max-w-4xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32 w-full">
                <h1 class="pt-20 fade-in delay-1 text-2xl md:text-3xl tracking-[0.3em] uppercase text-white/90 font-light">
                    For Your Joyful Gatherings and Events
                </h1>
            </div>

            <!-- Bottom: Buttons -->
            <div class="relative z-[3] text-center text-white max-w-4xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32 w-full">
                <div class="fade-in delay-4 flex flex-wrap gap-4 justify-center">
                    <a
                        href="/contact"
                        class="inline-flex shrink-0 items-center justify-center whitespace-nowrap rounded-sm border border-white bg-white px-8 py-4 font-sans text-sm font-medium uppercase tracking-[0.15em] text-charcoal transition-all duration-[600ms] ease-out hover:bg-sage hover:text-white hover:border-sage active:scale-95 cursor-pointer"
                    >
                        Book a Private Tour
                    </a>
                    <a
                        href="tel:+15201234567"
                        class="inline-flex shrink-0 items-center justify-center whitespace-nowrap rounded-sm border border-white bg-transparent px-8 py-4 font-sans text-sm font-medium uppercase tracking-[0.15em] text-white transition-all duration-[600ms] ease-out hover:bg-white hover:text-charcoal active:scale-95 cursor-pointer"
                    >
                        Give us a call
                    </a>
                </div>
            </div>

            <div class="absolute bottom-10 left-1/2 z-[3] -translate-x-1/2 animate-bounce-slow">
                <div class="w-px h-12 bg-white/40"></div>
            </div>
        </section>

        <!-- Email Capture -->
        <section class="bg-sage py-5">
            <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-4 text-center md:text-left px-6 md:px-12 lg:px-20 xl:px-32">
                <p class="text-white text-[0.9375rem] font-light">
                    <strong class="font-medium font-serif text-lg">Join the Himaya Garden Newsletter</strong> to learn more about our upcoming events, retreats,
                    and workshops
                </p>
                <form class="flex gap-2 w-full max-w-md" onsubmit="event.preventDefault(); window.location.href='/contact';">
                    <input
                        type="email"
                        placeholder="Your email address"
                        required
                        class="flex-1 px-4 py-3 border border-white/30 bg-white/10 text-white rounded-sm text-sm placeholder:text-white/60 focus:outline-none focus:bg-white/20 focus:border-white/60"
                    />
                    <button
                        type="submit"
                        class="px-6 py-3 bg-white text-sage-dark font-medium text-xs tracking-[0.15em] uppercase rounded-sm cursor-pointer transition-all whitespace-nowrap hover:bg-cream"
                    >
                        Join!
                    </button>
                </form>
            </div>
        </section>

        <!-- Marquee -->
        <div class="bg-cream-warm py-5 overflow-hidden whitespace-nowrap border-y border-sage/10">
            <div class="inline-flex animate-marquee">
                <span class="font-serif text-lg text-sage px-8 inline-flex items-center gap-8">
                    Weddings <span class="w-1 h-1 bg-sage rounded-full opacity-50"></span>
                </span>
                <span class="font-serif text-lg text-sage px-8 inline-flex items-center gap-8">
                    Retreats <span class="w-1 h-1 bg-sage rounded-full opacity-50"></span>
                </span>
                <span class="font-serif text-lg text-sage px-8 inline-flex items-center gap-8">
                    Private Celebrations <span class="w-1 h-1 bg-sage rounded-full opacity-50"></span>
                </span>
                <span class="font-serif text-lg text-sage px-8 inline-flex items-center gap-8">
                    Workshops <span class="w-1 h-1 bg-sage rounded-full opacity-50"></span>
                </span>
                <span class="font-serif text-lg text-sage px-8 inline-flex items-center gap-8">
                    High Tea <span class="w-1 h-1 bg-sage rounded-full opacity-50"></span>
                </span>
                <span class="font-serif text-lg text-sage px-8 inline-flex items-center gap-8">
                    Garden Tours <span class="w-1 h-1 bg-sage rounded-full opacity-50"></span>
                </span>
                <span class="font-serif text-lg text-sage px-8 inline-flex items-center gap-8">
                    Sunset Ceremonies <span class="w-1 h-1 bg-sage rounded-full opacity-50"></span>
                </span>
                <span class="font-serif text-lg text-sage px-8 inline-flex items-center gap-8">
                    Filipino Heritage Dining <span class="w-1 h-1 bg-sage rounded-full opacity-50"></span>
                </span>
                <span class="font-serif text-lg text-sage px-8 inline-flex items-center gap-8">
                    Weddings <span class="w-1 h-1 bg-sage rounded-full opacity-50"></span>
                </span>
                <span class="font-serif text-lg text-sage px-8 inline-flex items-center gap-8">
                    Retreats <span class="w-1 h-1 bg-sage rounded-full opacity-50"></span>
                </span>
                <span class="font-serif text-lg text-sage px-8 inline-flex items-center gap-8">
                    Private Celebrations <span class="w-1 h-1 bg-sage rounded-full opacity-50"></span>
                </span>
                <span class="font-serif text-lg text-sage px-8 inline-flex items-center gap-8">
                    Workshops <span class="w-1 h-1 bg-sage rounded-full opacity-50"></span>
                </span>
                <span class="font-serif text-lg text-sage px-8 inline-flex items-center gap-8">
                    High Tea <span class="w-1 h-1 bg-sage rounded-full opacity-50"></span>
                </span>
                <span class="font-serif text-lg text-sage px-8 inline-flex items-center gap-8">
                    Garden Tours <span class="w-1 h-1 bg-sage rounded-full opacity-50"></span>
                </span>
                <span class="font-serif text-lg text-sage px-8 inline-flex items-center gap-8">
                    Sunset Ceremonies <span class="w-1 h-1 bg-sage rounded-full opacity-50"></span>
                </span>
                <span class="font-serif text-lg text-sage px-8 inline-flex items-center gap-8">
                    Filipino Heritage Dining <span class="w-1 h-1 bg-sage rounded-full opacity-50"></span>
                </span>
            </div>
        </div>

        <!-- Intro -->
        <section class="py-24 md:py-32 bg-cream">
            <div class="max-w-7xl mx-auto text-center px-6 md:px-12 lg:px-20 xl:px-32">
                <p class="section-label fade-in">Himaya Garden is a sanctuary</p>
                <h2 class="fade-in delay-1 font-serif text-4xl md:text-5xl lg:text-6xl font-light leading-tight mb-8 text-charcoal">
                    For Celebrations, Connection,<br />and Belonging
                </h2>
                <p class="fade-in delay-2 text-lg text-stone leading-relaxed">
                    Whether you're planning a wedding, retreat, private celebration, or immersive workshop, Himaya Garden offers an experience your
                    guests will lovingly remember long after they leave.
                </p>
            </div>
        </section>

        <!-- Stats -->
        <section class="py-16 bg-warm-white">
            <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
                    <div class="fade-in">
                        <div class="font-serif text-5xl md:text-[3.5rem] font-medium text-sage leading-none mb-3">25+</div>
                        <div class="text-sm text-stone font-light tracking-wide">Years of Hospitality Experience</div>
                    </div>
                    <div class="fade-in delay-1">
                        <div class="font-serif text-5xl md:text-[3.5rem] font-medium text-sage leading-none mb-3">500+</div>
                        <div class="text-sm text-stone font-light tracking-wide">Events Hosted</div>
                    </div>
                    <div class="fade-in delay-2">
                        <div class="font-serif text-5xl md:text-[3.5rem] font-medium text-sage leading-none mb-3">3</div>
                        <div class="text-sm text-stone font-light tracking-wide">Generations of Recipes</div>
                    </div>
                    <div class="fade-in delay-3">
                        <div class="font-serif text-5xl md:text-[3.5rem] font-medium text-sage leading-none mb-3">1</div>
                        <div class="text-sm text-stone font-light tracking-wide">Desert Sanctuary</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Events Hover -->
        <section class="py-24 md:py-32 bg-cream">
            <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="text-center mb-16">
                    <p class="section-label fade-in">A Desert Sanctuary for<br />Meaningful Gatherings</p>
                    <h2 class="fade-in delay-1 font-serif text-4xl md:text-5xl lg:text-6xl font-light leading-tight text-charcoal">
                        Designed for Mindful Presence and Joyful Moments
                    </h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
                    <div class="fade-in relative rounded-sm overflow-hidden aspect-[3/4] cursor-pointer group">
                        <img
                            src="/media/img/wedding-venue.webp"
                            alt="Weddings"
                            class="w-full h-full object-cover transition-transform duration-[2000ms] ease-out group-hover:scale-[1.08]"
                        />
                        <div
                            class="absolute inset-0 bg-gradient-to-t from-charcoal/85 via-charcoal/20 to-transparent flex flex-col justify-end p-8 transition-all duration-[600ms] group-hover:from-charcoal/92 group-hover:via-charcoal/40"
                        >
                            <h3 class="font-serif text-2xl text-white mb-2 transition-transform duration-[600ms]">Weddings</h3>
                            <div class="opacity-0 translate-y-5 transition-all duration-[600ms] group-hover:opacity-100 group-hover:translate-y-0">
                                <p class="text-[0.9375rem] text-white/80 font-light leading-relaxed mb-5">
                                    Sunset ceremonies, receptions for up to 120, and heritage-inspired menus that make your day unforgettable.
                                </p>
                                <a
                                    href="/contact"
                                    class="inline-flex items-center gap-2 text-xs tracking-[0.15em] uppercase text-white font-medium transition-all duration-[400ms] hover:gap-3"
                                >
                                    Inquire
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
                                        <path d="M5 12h14M12 5l7 7-7 7"></path>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="fade-in delay-1 relative rounded-sm overflow-hidden aspect-[3/4] cursor-pointer group">
                        <img
                            src="/media/img/wellness-img.png"
                            alt="Retreats"
                            class="w-full h-full object-cover transition-transform duration-[2000ms] ease-out group-hover:scale-[1.08]"
                        />
                        <div
                            class="absolute inset-0 bg-gradient-to-t from-charcoal/85 via-charcoal/20 to-transparent flex flex-col justify-end p-8 transition-all duration-[600ms] group-hover:from-charcoal/92 group-hover:via-charcoal/40"
                        >
                            <h3 class="font-serif text-2xl text-white mb-2 transition-transform duration-[600ms]">Retreats</h3>
                            <div class="opacity-0 translate-y-5 transition-all duration-[600ms] group-hover:opacity-100 group-hover:translate-y-0">
                                <p class="text-[0.9375rem] text-white/80 font-light leading-relaxed mb-5">
                                    Wellness weekends, team offsites, and creative workshops in a space designed for stillness and focus.
                                </p>
                                <a
                                    href="/contact"
                                    class="inline-flex items-center gap-2 text-xs tracking-[0.15em] uppercase text-white font-medium transition-all duration-[400ms] hover:gap-3"
                                >
                                    Inquire
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
                                        <path d="M5 12h14M12 5l7 7-7 7"></path>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="fade-in delay-2 relative rounded-sm overflow-hidden aspect-[3/4] cursor-pointer group">
                        <img
                            src="/media/img/private-celebration.jpg"
                            alt="Private Celebrations"
                            class="w-full h-full object-cover transition-transform duration-[2000ms] ease-out group-hover:scale-[1.08]"
                        />
                        <div
                            class="absolute inset-0 bg-gradient-to-t from-charcoal/85 via-charcoal/20 to-transparent flex flex-col justify-end p-8 transition-all duration-[600ms] group-hover:from-charcoal/92 group-hover:via-charcoal/40"
                        >
                            <h3 class="font-serif text-2xl text-white mb-2 transition-transform duration-[600ms]">Private Celebrations</h3>
                            <div class="opacity-0 translate-y-5 transition-all duration-[600ms] group-hover:opacity-100 group-hover:translate-y-0">
                                <p class="text-[0.9375rem] text-white/80 font-light leading-relaxed mb-5">
                                    Milestones, reunions, and anniversaries in a hidden sanctuary built for connection over crowds.
                                </p>
                                <a
                                    href="/contact"
                                    class="inline-flex items-center gap-2 text-xs tracking-[0.15em] uppercase text-white font-medium transition-all duration-[400ms] hover:gap-3"
                                >
                                    Inquire
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
                                        <path d="M5 12h14M12 5l7 7-7 7"></path>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="fade-in delay-3 relative rounded-sm overflow-hidden aspect-[3/4] cursor-pointer group">
                        <img
                            src="/media/img/workshop.webp"
                            alt="Workshops"
                            class="w-full h-full object-cover transition-transform duration-[2000ms] ease-out group-hover:scale-[1.08]"
                        />
                        <div
                            class="absolute inset-0 bg-gradient-to-t from-charcoal/85 via-charcoal/20 to-transparent flex flex-col justify-end p-8 transition-all duration-[600ms] group-hover:from-charcoal/92 group-hover:via-charcoal/40"
                        >
                            <h3 class="font-serif text-2xl text-white mb-2 transition-transform duration-[600ms]">Workshops</h3>
                            <div class="opacity-0 translate-y-5 transition-all duration-[600ms] group-hover:opacity-100 group-hover:translate-y-0">
                                <p class="text-[0.9375rem] text-white/80 font-light leading-relaxed mb-5">
                                    Cooking classes, art sessions, and cultural programming in a garden that inspires creation.
                                </p>
                                <a
                                    href="/contact"
                                    class="inline-flex items-center gap-2 text-xs tracking-[0.15em] uppercase text-white font-medium transition-all duration-[400ms] hover:gap-3"
                                >
                                    Inquire
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
                                        <path d="M5 12h14M12 5l7 7-7 7"></path>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="text-center fade-in">
                    <a href="/contact" class="btn-primary">Book a Private Tour</a>
                </div>
            </div>
        </section>

        <!-- High Tea -->
        <section class="py-24 md:py-32 bg-warm-white">
            <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
                    <div>
                        <p class="section-label fade-in">Our Signature High Tea</p>
                        <h2 class="fade-in delay-1 font-serif text-4xl md:text-5xl lg:text-6xl font-light leading-tight mb-6 text-charcoal"></h2>
                        <div class="fade-in delay-2">
                            <p class="text-lg text-stone leading-relaxed mb-5">
                                Our most requested sold out gathering. A culinary experience of delicate pastries, heritage-inspired finger foods, and
                                botanical teas.
                            </p>
                            <p class="text-stone leading-relaxed mb-6">
                                Rooted in the tradition of Filipino merienda and reimagined through three generations of bakers, our High Tea is more
                                than a meal — it is a slowing down. A remembering. A celebration of the sweet and savory moments that connect us.
                            </p>
                            <ul class="list-none mb-8">
                                <li class="flex items-start gap-3 py-3 text-stone text-[0.9375rem] font-light border-b border-charcoal/5">
                                    <span class="text-sage text-xl leading-none">◈</span> Seasonal menu crafted by Odette & Milana
                                </li>
                                <li class="flex items-start gap-3 py-3 text-stone text-[0.9375rem] font-light border-b border-charcoal/5">
                                    <span class="text-sage text-xl leading-none">◈</span> Tea house seating for up to 30 guests
                                </li>
                                <li class="flex items-start gap-3 py-3 text-stone text-[0.9375rem] font-light border-b border-charcoal/5">
                                    <span class="text-sage text-xl leading-none">◈</span> Perfect for bridal showers, birthdays, retirements, or corporate
                                    meetings
                                </li>
                                <li class="flex items-start gap-3 py-3 text-stone text-[0.9375rem] font-light border-b border-charcoal/5">
                                    <span class="text-sage text-xl leading-none">◈</span> Public High Teas are held monthly, signup for <a
                                        href="#"
                                        class="underline hover:text-sage transition-colors"
                                    >
                                        Himaya Garden Newsletter for an exclusive invitation
                                    </a>
                                </li>
                            </ul>
                        </div>
                        <div class="fade-in delay-3 flex flex-wrap gap-4 items-center">
                            <a href="/contact" class="btn-primary">Reserve High Tea</a>
                            <a href="/events" class="btn-secondary">View All Events</a>
                        </div>
                    </div>
                    <div class="fade-in delay-2">
                        <img src="/media/img/tea-circles.webp" alt="High Tea at Himaya Garden" class="w-full h-auto rounded-sm" />
                    </div>
                </div>
            </div>
        </section>

        <!-- Features -->
        <section class="py-24 md:py-32 bg-warm-white">
            <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="text-center mb-16 max-w-2xl mx-auto">
                    <p class="section-label fade-in">A Botanical Sanctuary in the Heart of Tucson</p>
                    <h2 class="fade-in delay-1 font-serif text-4xl md:text-5xl font-light leading-tight text-charcoal">
                        Step into lush greenery, desert blooms, and intimate gathering spaces
                    </h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                    <div class="fade-in text-center p-8 transition-all duration-[600ms] hover:bg-cream rounded">
                        <div class="inline-flex text-sage mb-6 transition-colors duration-[500ms] hover:text-sage-dark">
                            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M24 4C24 4 12 12 12 24C12 32 17 40 24 44C31 40 36 32 36 24C36 12 24 4 24 4Z"></path>
                                <path d="M24 14V34"></path>
                                <path d="M18 20C18 20 21 18 24 18C27 18 30 20 30 20"></path>
                                <path d="M18 28C18 28 21 26 24 26C27 26 30 28 30 28"></path>
                            </svg>
                        </div>
                        <h3 class="font-serif text-xl mb-4 text-charcoal leading-snug">Private garden venue with layered outdoor spaces</h3>
                        <p class="text-sm text-stone leading-relaxed">
                            Lush greenery, curated garden paths, and intimate gathering spaces designed for beauty and flow.
                        </p>
                    </div>
                    <div class="fade-in delay-1 text-center p-8 transition-all duration-[600ms] hover:bg-cream rounded">
                        <div class="inline-flex text-sage mb-6 transition-colors duration-[500ms] hover:text-sage-dark">
                            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                                <circle cx="24" cy="24" r="8"></circle>
                                <path d="M24 8V16"></path>
                                <path d="M24 32V40"></path>
                                <path d="M8 24H16"></path>
                                <path d="M32 24H40"></path>
                                <path d="M12.7 12.7L18.3 18.3"></path>
                                <path d="M29.7 29.7L35.3 35.3"></path>
                                <path d="M12.7 35.3L18.3 29.7"></path>
                                <path d="M29.7 18.3L35.3 12.7"></path>
                            </svg>
                        </div>
                        <h3 class="font-serif text-xl mb-4 text-charcoal leading-snug">Desert-meets-botanical aesthetic</h3>
                        <p class="text-sm text-stone leading-relaxed">
                            Where desert resilience meets botanical care — strength and softness in harmony.
                        </p>
                    </div>
                    <div class="fade-in delay-2 text-center p-8 transition-all duration-[600ms] hover:bg-cream rounded">
                        <div class="inline-flex text-sage mb-6 transition-colors duration-[500ms] hover:text-sage-dark">
                            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                                <rect x="8" y="12" width="32" height="24" rx="2"></rect>
                                <circle cx="24" cy="24" r="6"></circle>
                                <path d="M8 20L16 14L24 20"></path>
                                <path d="M32 26L40 20L40 32"></path>
                            </svg>
                        </div>
                        <h3 class="font-serif text-xl mb-4 text-charcoal leading-snug">Naturally photogenic at every angle</h3>
                        <p class="text-sm text-stone leading-relaxed">The garden already tells a story. Your event doesn't need to be "styled."</p>
                    </div>
                    <div class="fade-in delay-3 text-center p-8 transition-all duration-[600ms] hover:bg-cream rounded">
                        <div class="inline-flex text-sage mb-6 transition-colors duration-[500ms] hover:text-sage-dark">
                            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M4 36H44"></path>
                                <path d="M8 32C8 32 16 24 24 24C32 24 40 32 40 32"></path>
                                <circle cx="24" cy="16" r="6"></circle>
                                <path d="M12 12L16 16"></path>
                                <path d="M36 12L32 16"></path>
                                <path d="M24 6V10"></path>
                            </svg>
                        </div>
                        <h3 class="font-serif text-xl mb-4 text-charcoal leading-snug">Sunset ceremonies that require no extra décor</h3>
                        <p class="text-sm text-stone leading-relaxed">That golden hour moment when the desert softens and the light turns magical.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Food -->
        <section class="py-24 md:py-32 bg-cream">
            <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col gap-4">
                            <div class="rounded-sm overflow-hidden aspect-[4/5]">
                                <img
                                    src="/media/img/collage-2.webp"
                                    alt="Himaya Garden catering"
                                    class="w-full h-full object-cover transition-transform duration-[2000ms] hover:scale-[1.05]"
                                />
                            </div>
                        </div>
                        <div class="flex flex-col gap-4 mt-8">
                            <div class="rounded-sm overflow-hidden aspect-[4/5]">
                                <img
                                    src="/media/img/collage-3_4.webp"
                                    alt="Filipino-inspired cuisine"
                                    class="w-full h-full object-cover transition-transform duration-[2000ms] hover:scale-[1.05]"
                                />
                            </div>
                            <div class="rounded-sm overflow-hidden aspect-[4/3]">
                                <img
                                    src="/media/img/collage-3_7.webp"
                                    alt="Garden dining"
