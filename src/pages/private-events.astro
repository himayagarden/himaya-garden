    <!-- Multi-Video Horizontal Slider Script -->
    <script>
        (function (): void {
            const slider = document.querySelector<HTMLElement>('.video-slider');
            if (!slider) return;

            const track = slider.querySelector<HTMLElement>('.slider-track');
            const items = slider.querySelectorAll<HTMLElement>('.slider-item');
            const prevBtn = slider.querySelector<HTMLButtonElement>('.slider-prev');
            const nextBtn = slider.querySelector<HTMLButtonElement>('.slider-next');
            const dots = slider.querySelectorAll<HTMLButtonElement>('.slider-dot');

            let currentIndex: number = 0;
            let itemsPerView: number = getItemsPerView();
            const totalItems: number = items.length;
            let maxIndex: number = Math.max(0, totalItems - itemsPerView);

            function getItemsPerView(): number {
                if (window.innerWidth >= 1024) return 3;
                if (window.innerWidth >= 768) return 2;
                return 1;
            }

            function updateSlider(): void {
                if (!track) return;
                const itemWidth: number = 100 / itemsPerView;
                track.style.transform = `translateX(-${currentIndex * itemWidth}%)`;

                // Update dots
                dots.forEach((dot: HTMLButtonElement, i: number) => {
                    dot.classList.toggle('active', i === currentIndex);
                });

                // Play visible videos, pause hidden ones
                items.forEach((item: HTMLElement, i: number) => {
                    const video = item.querySelector<HTMLVideoElement>('video');
                    if (i >= currentIndex && i < currentIndex + itemsPerView) {
                        if (video) video.play().catch(() => {});
                    } else {
                        if (video) {
                            video.pause();
                            video.currentTime = 0;
                        }
                    }
                });
            }

            function next(): void {
                if (currentIndex < maxIndex) {
                    currentIndex++;
                } else {
                    currentIndex = 0; // Loop back to start
                }
                updateSlider();
            }

            function prev(): void {
                if (currentIndex > 0) {
                    currentIndex--;
                } else {
                    currentIndex = maxIndex; // Loop to end
                }
                updateSlider();
            }

            function goToSlide(index: number): void {
                currentIndex = Math.min(Math.max(index, 0), maxIndex);
                updateSlider();
            }

            // Event listeners
            prevBtn?.addEventListener('click', prev);
            nextBtn?.addEventListener('click', next);

            dots.forEach((dot: HTMLButtonElement, i: number) => {
                dot.addEventListener('click', () => goToSlide(i));
            });

            // Touch / swipe support
            let touchStartX: number = 0;
            let touchEndX: number = 0;

            track?.addEventListener(
                'touchstart',
                (e: TouchEvent) => {
                    touchStartX = e.changedTouches[0].screenX;
                },
                { passive: true },
            );

            track?.addEventListener(
                'touchend',
                (e: TouchEvent) => {
                    touchEndX = e.changedTouches[0].screenX;
                    const diff: number = touchStartX - touchEndX;
                    if (Math.abs(diff) > 50) {
                        if (diff > 0) next();
                        else prev();
                    }
                },
                { passive: true },
            );

            // Mouse drag support
            let isDragging: boolean = false;
            let startX: number = 0;

            track?.addEventListener('mousedown', (e: MouseEvent) => {
                isDragging = true;
                startX = e.pageX;
                track.style.cursor = 'grabbing';
            });

            track?.addEventListener('mousemove', (e: MouseEvent) => {
                if (!isDragging) return;
                e.preventDefault();
            });

            track?.addEventListener('mouseup', (e: MouseEvent) => {
                if (!isDragging) return;
                isDragging = false;
                track.style.cursor = 'grab';
                const diff: number = startX - e.pageX;
                if (Math.abs(diff) > 50) {
                    if (diff > 0) next();
                    else prev();
                }
            });

            track?.addEventListener('mouseleave', () => {
                isDragging = false;
                if (track) track.style.cursor = 'grab';
            });

            // Handle resize
            window.addEventListener('resize', () => {
                const newItemsPerView: number = getItemsPerView();
                if (newItemsPerView !== itemsPerView) {
                    itemsPerView = newItemsPerView;
                    maxIndex = Math.max(0, totalItems - itemsPerView);
                    currentIndex = Math.min(currentIndex, maxIndex);
                    updateSlider();
                }
            });

            // Autoplay
            const autoplayEnabled: boolean = slider.dataset.autoplay === 'true';
            const intervalTime: number = parseInt(slider.dataset.interval || '6000', 10);
            let autoplayTimer: ReturnType<typeof setInterval> | null = null;

            if (autoplayEnabled) {
                autoplayTimer = setInterval(next, intervalTime);

                // Pause on hover
                slider.addEventListener('mouseenter', () => {
                    if (autoplayTimer) clearInterval(autoplayTimer);
                });

                slider.addEventListener('mouseleave', () => {
                    autoplayTimer = setInterval(next, intervalTime);
                });
            }

            // Tab visibility
            document.addEventListener('visibilitychange', () => {
                if (document.hidden) {
                    items.forEach((item: HTMLElement) => {
                        const video = item.querySelector<HTMLVideoElement>('video');
                        if (video) video.pause();
                    });
                } else {
                    updateSlider();
                }
            });

            // Initialize
            if (track) track.style.cursor = 'grab';
            updateSlider();
        })();
    </script>
</BaseLayout>

<style>
    /* Multi-Video Horizontal Slider Styles */
    .slider-track-wrapper {
        overflow: hidden;
        margin: 0 -0.5rem;
    }

    .slider-track {
        display: flex;
        transition: transform 0.7s ease-in-out;
        will-change: transform;
    }

    .slider-item {
        flex: 0 0 auto;
        padding: 0.5rem;
    }

    /* Widths handled by Tailwind classes: w-full md:w-1/2 lg:w-1/3 */

    /* Vertical video slider - full height */
    .slider-track {
        height: 70vh;
    }

    @media (min-width: 768px) {
        .slider-track {
            height: 80vh;
        }
    }

    .slider-item {
        height: 100%;
    }

    .slider-item > div {
        height: 100%;
    }

    .slider-item video,
    .slider-item img {
        height: 100%;
        width: auto;
        max-width: none;
        object-fit: cover;
    }

    /* Dots */
    .slider-dot {
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 9999px;
        background-color: rgba(120, 113, 108, 0.3);
        transition: all 0.3s ease;
        cursor: pointer;
        border: none;
        padding: 0;
    }

    .slider-dot.active {
        width: 2rem;
        background-color: #a3b18a; /* sage color */
    }

    /* Focus styles */
    .slider-prev:focus,
    .slider-next:focus,
    .slider-dot:focus {
        outline: 2px solid #a3b18a;
        outline-offset: 2px;
    }

    /* Prevent text selection during drag */
    .slider-track {
        user-select: none;
        -webkit-user-select: none;
    }
</style>
