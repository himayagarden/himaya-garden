---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
    title="Private High Tea — Himaya Garden"
    description="Experience an elegant private high tea at Himaya Garden in Tucson, Arizona. Filipino-inspired and Classic High Tea menus for intimate gatherings, showers, and celebrations."
>
    <main>
        <!-- Page Header -->
        <section class="pt-32 pb-20 bg-cream">
            <div class="max-w-6xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32 text-center">
                <p class="section-label fade-in">Tea House Experience</p>
                <h1 class="fade-in delay-1 font-serif text-4xl md:text-6xl lg:text-7xl font-medium tracking-tight leading-tight text-charcoal mb-6">
                    Private High Tea
                </h1>
                <p class="fade-in delay-2 text-lg text-stone leading-relaxed max-w-2xl mx-auto mb-10">
                    An intimate, elegant gathering where thoughtful hospitality, beautiful tablescapes, and unforgettable flavors come together in our
                    Tucson tea house.
                </p>

                <!-- Quick Nav -->
                <div class="fade-in delay-3 flex flex-wrap justify-center gap-3">
                    <a
                        href="#filipino-menu"
                        class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-sage/10 text-sage hover:bg-sage hover:text-white transition-all font-medium text-sm tracking-wide"
                    >
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"
                            >
                            </path>
                        </svg>
                        Filipino Inspired
                    </a>
                    <a
                        href="#classic-menu"
                        class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-sage/10 text-sage hover:bg-sage hover:text-white transition-all font-medium text-sm tracking-wide"
                    >
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z">
                            </path>
                        </svg>
                        Classic High Tea
                    </a>
                    <a
                        href="#video-gallery"
                        class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-sage/10 text-sage hover:bg-sage hover:text-white transition-all font-medium text-sm tracking-wide"
                    >
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"
                            >
                            </path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        Watch the Experience
                    </a>
                </div>
            </div>
        </section>

        <!-- Introduction -->
        <section class="py-24 bg-cream">
            <div class="max-w-6xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="text-center max-w-3xl mx-auto">
                    <h2 class="font-serif text-3xl md:text-5xl font-medium tracking-tight leading-tight text-charcoal mb-8">
                        A Tea Party Experience Designed to Feel Effortless
                    </h2>
                    <div class="space-y-6 text-stone text-lg leading-relaxed">
                        <p>
                            The Tea House Collection is perfect for hosts who want a refined yet relaxed celebration — one where every detail feels
                            intentional and every guest feels cared for.
                        </p>
                        <p>
                            Choose between our <span class="text-charcoal font-medium">Filipino Inspired High Tea</span> or <span
                                class="text-charcoal font-medium"
                            >
                                Classic High Tea
                            </span> menu, each thoughtfully curated and served to your guests in the elegant setting of our Tucson tea house.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Video Slider Section - Multi-Video Horizontal Layout -->
        <section id="video-gallery" class="py-24 bg-cream-warm scroll-mt-24">
            <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="text-center mb-16">
                    <p class="section-label fade-in">See It Come to Life</p>
                    <h2 class="fade-in delay-1 font-serif text-3xl md:text-5xl font-medium tracking-tight leading-tight text-charcoal">
                        The High Tea Experience
                    </h2>
                    <p class="fade-in delay-2 text-stone mt-4 max-w-2xl mx-auto text-lg leading-relaxed">
                        Step inside our tea house. Watch how we craft each gathering with care, from the tablescapes to the final sip.
                    </p>
                </div>

                <!-- Multi-Video Horizontal Slider -->
                <div class="video-slider" data-autoplay="true" data-interval="6000">
                    <!-- Slider Track -->
                    <div class="slider-track-wrapper overflow-hidden">
                        <div class="slider-track flex transition-transform duration-700 ease-in-out h-[70vh] md:h-[80vh]">
                            <!-- Video Slide 1 -->
                            <div class="slider-item flex-shrink-0 w-full md:w-1/2 lg:w-1/3 p-2">
                                <div class="relative rounded-xl overflow-hidden bg-charcoal group h-full">
                                    <div class="h-full relative">
                                        <video
                                            src="/videos/tea-house-tour.mp4"
                                            poster="/img/high-tea/tea-house-poster.jpg"
                                            class="slide-video w-full h-full object-cover"
                                            playsinline
                                            muted
                                            loop
                                            autoplay
                                            preload="metadata"
                                        >
                                        </video>
                                        <div class="absolute inset-0 bg-gradient-to-t from-charcoal/70 via-transparent to-transparent"></div>
                                        <div class="absolute bottom-0 left-0 right-0 p-5">
                                            <p class="text-white/70 text-xs uppercase tracking-wider mb-1">Experience</p>
                                            <h3 class="font-serif text-xl text-white">Welcome to the Tea House</h3>
                                        </div>
                                        <!-- Play overlay on hover -->
                                        <div
                                            class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-charcoal/20"
                                        >
                                            <div class="w-14 h-14 rounded-full bg-white/90 flex items-center justify-center text-charcoal">
                                                <svg class="w-6 h-6 ml-1" fill="currentColor" viewBox="0 0 24 24">
                                                    <path d="M8 5v14l11-7z"></path>
                                                </svg>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Video Slide 2 -->
                            <div class="slider-item flex-shrink-0 w-full md:w-1/2 lg:w-1/3 p-2">
                                <div class="relative rounded-xl overflow-hidden bg-charcoal group h-full">
                                    <div class="aspect-[9/16] md:aspect-[3/4] relative">
                                        <video
                                            src="/videos/filipino-high-tea.mp4"
                                            poster="/img/high-tea/filipino-tea-poster.jpg"
                                            class="slide-video w-full h-full object-cover"
                                            playsinline
                                            muted
                                            loop
                                            preload="metadata"
                                        >
                                        </video>
                                        <div class="absolute inset-0 bg-gradient-to-t from-charcoal/70 via-transparent to-transparent"></div>
                                        <div class="absolute bottom-0 left-0 right-0 p-5">
                                            <p class="text-white/70 text-xs uppercase tracking-wider mb-1">Menu</p>
                                            <h3 class="font-serif text-xl text-white">Filipino Inspired High Tea</h3>
                                        </div>
                                        <div
                                            class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-charcoal/20"
                                        >
                                            <div class="w-14 h-14 rounded-full bg-white/90 flex items-center justify-center text-charcoal">
                                                <svg class="w-6 h-6 ml-1" fill="currentColor" viewBox="0 0 24 24">
                                                    <path d="M8 5v14l11-7z"></path>
                                                </svg>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Video Slide 3 -->
                            <div class="slider-item flex-shrink-0 w-full md:w-1/2 lg:w-1/3 p-2">
                                <div class="relative rounded-xl overflow-hidden bg-charcoal group h-full">
                                    <div class="aspect-[9/16] md:aspect-[3/4] relative">
                                        <video
                                            src="/videos/classic-high-tea.mp4"
                                            poster="/img/high-tea/classic-tea-poster.jpg"
                                            class="slide-video w-full h-full object-cover"
                                            playsinline
                                            muted
                                            loop
                                            preload="metadata"
                                        >
                                        </video>
                                        <div class="absolute inset-0 bg-gradient-to-t from-charcoal/70 via-transparent to-transparent"></div>
                                        <div class="absolute bottom-0 left-0 right-0 p-5">
                                            <p class="text-white/70 text-xs uppercase tracking-wider mb-1">Menu</p>
                                            <h3 class="font-serif text-xl text-white">Classic High Tea Service</h3>
                                        </div>
                                        <div
                                            class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-charcoal/20"
                                        >
                                            <div class="w-14 h-14 rounded-full bg-white/90 flex items-center justify-center text-charcoal">
                                                <svg class="w-6 h-6 ml-1" fill="currentColor" viewBox="0 0 24 24">
                                                    <path d="M8 5v14l11-7z"></path>
                                                </svg>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Video Slide 4 -->
                            <div class="slider-item flex-shrink-0 w-full md:w-1/2 lg:w-1/3 p-2">
                                <div class="relative rounded-xl overflow-hidden bg-charcoal group h-full">
                                    <div class="aspect-[9/16] md:aspect-[3/4] relative">
                                        <video
                                            src="/videos/tablescape-design.mp4"
                                            poster="/img/high-tea/tablescape-poster.jpg"
                                            class="slide-video w-full h-full object-cover"
                                            playsinline
                                            muted
                                            loop
                                            preload="metadata"
                                        >
                                        </video>
                                        <div class="absolute inset-0 bg-gradient-to-t from-charcoal/70 via-transparent to-transparent"></div>
                                        <div class="absolute bottom-0 left-0 right-0 p-5">
                                            <p class="text-white/70 text-xs uppercase tracking-wider mb-1">Behind the Scenes</p>
                                            <h3 class="font-serif text-xl text-white">Art of the Tablescape</h3>
                                        </div>
                                        <div
                                            class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-charcoal/20"
                                        >
                                            <div class="w-14 h-14 rounded-full bg-white/90 flex items-center justify-center text-charcoal">
                                                <svg class="w-6 h-6 ml-1" fill="currentColor" viewBox="0 0 24 24">
                                                    <path d="M8 5v14l11-7z"></path>
                                                </svg>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Video Slide 5 -->
                            <div class="slider-item flex-shrink-0 w-full md:w-1/2 lg:w-1/3 p-2">
                                <div class="relative rounded-xl overflow-hidden bg-charcoal group h-full">
                                    <div class="aspect-[9/16] md:aspect-[3/4] relative">
                                        <video
                                            src="/videos/tea-prep.mp4"
                                            poster="/img/high-tea/tea-prep-poster.jpg"
                                            class="slide-video w-full h-full object-cover"
                                            playsinline
                                            muted
                                            loop
                                            preload="metadata"
                                        >
                                        </video>
                                        <div class="absolute inset-0 bg-gradient-to-t from-charcoal/70 via-transparent to-transparent"></div>
                                        <div class="absolute bottom-0 left-0 right-0 p-5">
                                            <p class="text-white/70 text-xs uppercase tracking-wider mb-1">Preparation</p>
                                            <h3 class="font-serif text-xl text-white">Brewing the Perfect Cup</h3>
                                        </div>
                                        <div
                                            class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-charcoal/20"
                                        >
                                            <div class="w-14 h-14 rounded-full bg-white/90 flex items-center justify-center text-charcoal">
                                                <svg class="w-6 h-6 ml-1" fill="currentColor" viewBox="0 0 24 24">
                                                    <path d="M8 5v14l11-7z"></path>
                                                </svg>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Video Slide 6 -->
                            <div class="slider-item flex-shrink-0 w-full md:w-1/2 lg:w-1/3 p-2">
                                <div class="relative rounded-xl overflow-hidden bg-charcoal group h-full">
                                    <div class="aspect-[9/16] md:aspect-[3/4] relative">
                                        <video
                                            src="/videos/guest-experience.mp4"
                                            poster="/img/high-tea/guest-experience-poster.jpg"
                                            class="slide-video w-full h-full object-cover"
                                            playsinline
                                            muted
                                            loop
                                            preload="metadata"
                                        >
                                        </video>
                                        <div class="absolute inset-0 bg-gradient-to-t from-charcoal/70 via-transparent to-transparent"></div>
                                        <div class="absolute bottom-0 left-0 right-0 p-5">
                                            <p class="text-white/70 text-xs uppercase tracking-wider mb-1">Atmosphere</p>
                                            <h3 class="font-serif text-xl text-white">A Guest's Perspective</h3>
                                        </div>
                                        <div
                                            class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-charcoal/20"
                                        >
                                            <div class="w-14 h-14 rounded-full bg-white/90 flex items-center justify-center text-charcoal">
                                                <svg class="w-6 h-6 ml-1" fill="currentColor" viewBox="0 0 24 24">
                                                    <path d="M8 5v14l11-7z"></path>
                                                </svg>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Navigation -->
                    <div class="flex items-center justify-center gap-6 mt-8">
                        <button
                            class="slider-prev w-12 h-12 rounded-full bg-sage/10 flex items-center justify-center text-sage hover:bg-sage hover:text-white transition-all"
                        >
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                            </svg>
                        </button>

                        <!-- Progress Dots -->
                        <div class="slider-dots flex items-center gap-2">
                            <button class="slider-dot active" data-slide="0" aria-label="Slide 1"></button>
                            <button class="slider-dot" data-slide="1" aria-label="Slide 2"></button>
                            <button class="slider-dot" data-slide="2" aria-label="Slide 3"></button>
                        </div>

                        <button
                            class="slider-next w-12 h-12 rounded-full bg-sage/10 flex items-center justify-center text-sage hover:bg-sage hover:text-white transition-all"
                        >
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                            </svg>
                        </button>
                    </div>

                    <p class="text-center text-stone text-sm mt-4">Swipe or drag to explore more videos</p>
                </div>
            </div>
        </section>

        <!-- Filipino Inspired High Tea -->
        <section id="filipino-menu" class="py-24 bg-cream scroll-mt-24">
            <div class="max-w-6xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="text-center mb-16">
                    <p class="section-label fade-in">Heritage & Heart</p>
                    <h2 class="fade-in delay-1 font-serif text-3xl md:text-5xl font-medium tracking-tight leading-tight text-charcoal">
                        Filipino Inspired High Tea
                    </h2>
                    <p class="fade-in delay-2 text-stone mt-4 max-w-2xl mx-auto text-lg leading-relaxed">
                        A celebration of Filipino flavors reimagined through the elegance of high tea service. Bold, comforting, and beautifully
                        presented.
                    </p>
                </div>

                <!-- Food Image Grid -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
                    <div class="rounded-xl overflow-hidden aspect-square">
                        <img
                            src="/img/high-tea/lumpia.jpg"
                            alt="Chef's Lumpia Sariwa"
                            class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                        />
                    </div>
                    <div class="rounded-xl overflow-hidden aspect-square">
                        <img
                            src="/img/high-tea/chicken-adobo.jpg"
                            alt="Chicken Adobo with Lemongrass Rice"
                            class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                        />
                    </div>
                    <div class="rounded-xl overflow-hidden aspect-square">
                        <img
                            src="/img/high-tea/pancit.jpg"
                            alt="Cebuano-Style Pancit"
                            class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                        />
                    </div>
                    <div class="rounded-xl overflow-hidden aspect-square">
                        <img
                            src="/img/high-tea/ube-biko.jpg"
                            alt="Ube Black Rice Biko"
                            class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                        />
                    </div>
                </div>

                <!-- Menu Details -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
                    <!-- Savory -->
                    <div class="bg-warm-white rounded-xl p-8 shadow-sm border border-stone/5">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="w-10 h-10 rounded-lg bg-sage/10 flex items-center justify-center text-sage">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                                    >
                                    </path>
                                </svg>
                            </div>
                            <h3 class="font-serif text-2xl text-charcoal">Savory</h3>
                        </div>
                        <ul class="space-y-3 text-stone leading-relaxed">
                            <li class="flex items-start gap-3">
                                <span class="text-sage mt-1">◆</span>
                                <span><strong class="text-charcoal">Tofu Sisig</strong> — A plant-forward take on the classic sizzling dish</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="text-sage mt-1">◆</span>
                                <span><strong class="text-charcoal">Chef's Lumpia Sariwa with Turkey</strong> — Fresh, hand-rolled spring rolls</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="text-sage mt-1">◆</span>
                                <span><strong class="text-charcoal">Chicken Adobo</strong> with Lemongrass Rice and Carrot & Papaya Atsara</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="text-sage mt-1">◆</span>
                                <span><strong class="text-charcoal">Cebuano-Style Pancit</strong> with Seasonal Vegetables</span>
                            </li>
                        </ul>
                    </div>

                    <!-- Sweet -->
                    <div class="bg-warm-white rounded-xl p-8 shadow-sm border border-stone/5">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="w-10 h-10 rounded-lg bg-sage/10 flex items-center justify-center text-sage">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M21 15.546c-.523 0-1.046.151-1.5.454a2.704 2.704 0 01-3 0 2.704 2.704 0 00-3 0 2.704 2.704 0 01-3 0 2.704 2.704 0 00-3 0 2.704 2.704 0 01-3 0 2.701 2.701 0 00-1.5-.454M9 6v2m3-2v2m3-2v2M9 3h.01M12 3h.01M15 3h.01M21 21v-7a2 2 0 00-2-2H5a2 2 0 00-2 2v7h18zm-3-9v-2a2 2 0 00-2-2H8a2 2 0 00-2 2v2h12z"
                                    >
                                    </path>
                                </svg>
                            </div>
                            <h3 class="font-serif text-2xl text-charcoal">Sweet</h3>
                        </div>
                        <ul class="space-y-3 text-stone leading-relaxed">
                            <li class="flex items-start gap-3">
                                <span class="text-sage mt-1">◆</span>
                                <span><strong class="text-charcoal">Ube Black Rice Biko</strong> — Creamy, earthy, and deeply comforting</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="text-sage mt-1">◆</span>
                                <span><strong class="text-charcoal">Chocolate Coconut Truffles</strong></span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="text-sage mt-1">◆</span>
                                <span><strong class="text-charcoal">Lemon Cakelettes</strong> by Dragonfly Cakes®</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="text-sage mt-1">◆</span>
                                <span><strong class="text-charcoal">Chocolate Covered Strawberries</strong></span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="text-sage mt-1">◆</span>
                                <span>Selection of <strong class="text-charcoal">Dragonfly Cakes® Tea Cakes</strong></span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="text-sage mt-1">◆</span>
                                <span>Fresh <strong class="text-charcoal">Seasonal Fruit</strong></span>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Sip Section -->
                <div class="mt-12 bg-sage/5 rounded-2xl p-10 max-w-4xl mx-auto border border-sage/20">
                    <div class="flex items-center gap-3 mb-6 justify-center">
                        <div class="w-10 h-10 rounded-lg bg-sage/10 flex items-center justify-center text-sage">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"
                                >
                                </path>
                            </svg>
                        </div>
                        <h3 class="font-serif text-2xl text-charcoal">Sip</h3>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div>
                            <p class="text-sage font-medium text-sm uppercase tracking-wider mb-3">Cool</p>
                            <ul class="space-y-2 text-stone">
                                <li>Prickly Pear Herbal Tea</li>
                                <li>Chai</li>
