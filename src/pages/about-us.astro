---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
    title="About Us — Himaya Garden"
    description="Discover the story of Himaya Garden. A mother-daughter owned events venue and tea house in Tucson, Arizona, rooted in Filipino heritage, hospitality, and intention."
>
    <main>
        <!-- Page Header -->
        <section class="pt-32 pb-20 bg-cream">
            <div class="max-w-6xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32 text-center">
                <p class="section-label fade-in">Our Story</p>
                <h1 class="fade-in delay-1 font-serif text-4xl md:text-6xl lg:text-7xl font-medium tracking-tight leading-tight text-charcoal mb-6">
                    About Us
                </h1>
                <p class="fade-in delay-2 text-lg text-stone leading-relaxed max-w-2xl mx-auto">Where Heritage, Hospitality, and Intention Meet</p>
            </div>
        </section>

        <!-- Rooted in Family -->
        <section class="py-24 bg-cream">
            <div class="max-w-6xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                    <div class="order-2 lg:order-1">
                        <p class="section-label mb-4">Our Beginning</p>
                        <h2 class="font-serif text-3xl md:text-4xl font-medium tracking-tight leading-tight text-charcoal mb-6">
                            Rooted in Family. Built With Heart.
                        </h2>
                        <div class="space-y-6 text-stone text-lg leading-relaxed">
                            <p>Himaya Garden began with a mother and daughter — and a legacy of flour-dusted hands and handwritten recipes.</p>
                            <p>
                                <strong class="text-charcoal">Odette D'Aniello</strong> and <strong class="text-charcoal">Milana D'Aniello</strong> are
                                third- and fourth-generation bakers whose roots trace back to Guam and the Philippines. In their family, food was never
                                just food. It was how love was expressed. How stories were told. How community was built.
                            </p>
                            <p>
                                Growing up Filipino-American, Milana felt immense pride in the strength, resilience, and joy of her heritage — yet
                                often noticed how underrepresented Filipino culture remained, despite being one of the largest Asian populations in
                                the United States.
                            </p>
                            <p class="font-serif text-2xl text-charcoal">Himaya Garden was born from a desire to change that.</p>
                            <p class="font-serif text-xl text-sage">Not loudly. But beautifully.</p>
                        </div>
                    </div>
                    <div class="order-1 lg:order-2">
                        <div class="relative">
                            <div class="rounded-2xl overflow-hidden shadow-lg">
                                <img
                                    src="media/img/Odette and Milana posing in front of Himaya Garden Mural.webp"
                                    alt="Odette and Milana D'Aniello, founders of Himaya Garden"
                                    style="height: 500px; width: 100%; background-position: left;"
                                    class="object-cover"
                                />
                            </div>
                            <div class="absolute -bottom-6 -left-6 bg-sage text-white rounded-xl px-6 py-4 shadow-lg hidden md:block">
                                <p class="font-serif text-lg">Est. 2023</p>
                                <p class="text-sm text-white/80">Tucson, Arizona</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- A Garden for Gathering -->
        <section class="py-24 bg-cream-warm">
            <div class="max-w-6xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="text-center max-w-3xl mx-auto mb-16">
                    <p class="section-label fade-in">Our Vision</p>
                    <h2 class="fade-in delay-1 font-serif text-3xl md:text-5xl font-medium tracking-tight leading-tight text-charcoal">
                        A Garden for Gathering
                    </h2>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-16">
                    <div class="rounded-2xl overflow-hidden shadow-lg">
                        <img src="/img/about/garden-sanctuary.jpg" alt="Himaya Garden outdoor venue space" class="w-full h-full object-cover" />
                    </div>
                    <div>
                        <p class="text-stone text-lg leading-relaxed mb-6">
                            With decades of experience in events and hospitality, Odette and Milana envisioned something different from the
                            traditional event venue.
                        </p>
                        <div class="space-y-4 mb-8">
                            <p class="font-serif text-2xl text-charcoal">Not a ballroom.</p>
                            <p class="font-serif text-2xl text-charcoal">Not a banquet hall.</p>
                            <p class="font-serif text-3xl text-sage">But a sanctuary.</p>
                        </div>
                        <p class="text-stone text-lg leading-relaxed mb-6">A space where:</p>
                        <ul class="space-y-4 mb-8">
                            <li class="flex items-start gap-3 text-stone text-lg">
                                <span class="text-sage text-xl mt-0.5">◈</span>
                                <span>Culture is celebrated</span>
                            </li>
                            <li class="flex items-start gap-3 text-stone text-lg">
                                <span class="text-sage text-xl mt-0.5">◈</span>
                                <span>Food carries memory</span>
                            </li>
                            <li class="flex items-start gap-3 text-stone text-lg">
                                <span class="text-sage text-xl mt-0.5">◈</span>
                                <span>Guests feel genuinely welcomed</span>
                            </li>
                            <li class="flex items-start gap-3 text-stone text-lg">
                                <span class="text-sage text-xl mt-0.5">◈</span>
                                <span>And celebrations unfold with intention</span>
                            </li>
                        </ul>
                        <p class="text-stone text-lg leading-relaxed">
                            At Himaya Garden, we honor our Cebuano roots while embracing the vibrancy of Tucson. The result is a venue that blends
                            desert resilience with botanical care — strength and softness in harmony.
                        </p>
                    </div>
                </div>

                <div class="text-center max-w-2xl mx-auto">
                    <p class="font-serif text-3xl md:text-4xl text-charcoal">Here, you are not just hosting an event.</p>
                    <p class="font-serif text-3xl md:text-4xl text-sage mt-2">You are creating meaning.</p>
                </div>
            </div>
        </section>

        <!-- Seamless. Professional. -->
        <section class="py-24 bg-cream">
            <div class="max-w-6xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="text-center mb-16">
                    <p class="section-label fade-in">Our Approach</p>
                    <h2 class="fade-in delay-1 font-serif text-3xl md:text-5xl font-medium tracking-tight leading-tight text-charcoal">
                        Seamless. Professional. Thoughtfully Executed.
                    </h2>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                    <div>
                        <p class="text-stone text-lg leading-relaxed mb-6">
                            With decades of experience in events and hospitality, Odette and Milana envisioned something different from the
                            traditional event venue.
                        </p>
                        <div class="space-y-4 mb-8">
                            <p class="font-serif text-2xl text-charcoal">Not a ballroom.</p>
                            <p class="font-serif text-2xl text-charcoal">Not a banquet hall.</p>
                            <p class="font-serif text-3xl text-sage">But a sanctuary.</p>
                        </div>
                        <p class="text-stone text-lg leading-relaxed mb-6">A space where:</p>
                        <ul class="space-y-4 mb-8">
                            <li class="flex items-start gap-3 text-stone text-lg">
                                <span class="text-sage text-xl mt-0.5">◈</span>
                                <span>Culture is celebrated</span>
                            </li>
                            <li class="flex items-start gap-3 text-stone text-lg">
                                <span class="text-sage text-xl mt-0.5">◈</span>
                                <span>Food carries memory</span>
                            </li>
                            <li class="flex items-start gap-3 text-stone text-lg">
                                <span class="text-sage text-xl mt-0.5">◈</span>
                                <span>Guests feel genuinely welcomed</span>
                            </li>
                            <li class="flex items-start gap-3 text-stone text-lg">
                                <span class="text-sage text-xl mt-0.5">◈</span>
                                <span>And celebrations unfold with intention</span>
                            </li>
                        </ul>
                        <p class="text-stone text-lg leading-relaxed">
                            At Himaya Garden, we honor our Cebuano roots while embracing the vibrancy of Tucson. The result is a venue that blends
                            desert resilience with botanical care — strength and softness in harmony.
                        </p>
                    </div>
                    <div class="rounded-2xl overflow-hidden shadow-lg">
                        <img src="/img/about/venue-details.jpg" alt="Himaya Garden event details and décor" class="w-full h-full object-cover" />
                    </div>
                </div>

                <div class="text-center max-w-2xl mx-auto mt-16">
                    <p class="font-serif text-3xl md:text-4xl text-charcoal">Here, you are not just hosting an event.</p>
                    <p class="font-serif text-3xl md:text-4xl text-sage mt-2">You are creating meaning.</p>
                </div>
            </div>
        </section>

        <!-- It's More Than A Venue -->
        <section class="py-24 bg-cream-warm">
            <div class="max-w-6xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="text-center mb-16">
                    <p class="section-label fade-in">Why Guests Choose Us</p>
                    <h2 class="fade-in delay-1 font-serif text-3xl md:text-5xl font-medium tracking-tight leading-tight text-charcoal">
                        It's More Than A Venue
                    </h2>
                </div>

                <div class="max-w-3xl mx-auto text-center mb-12">
                    <p class="text-stone text-lg leading-relaxed mb-8">Guests don't choose Himaya Garden simply because it's beautiful.</p>
                    <p class="text-stone text-lg leading-relaxed mb-10">They choose it because:</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto mb-16">
                    <div class="bg-white rounded-xl p-8 shadow-sm border border-stone/5 flex items-start gap-4 hover:-translate-y-1 transition-all">
                        <div class="w-10 h-10 rounded-full bg-sage/10 flex items-center justify-center text-sage shrink-0">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                        <p class="text-stone text-lg">It feels <strong class="text-charcoal">intimate yet elevated</strong></p>
                    </div>
                    <div class="bg-white rounded-xl p-8 shadow-sm border border-stone/5 flex items-start gap-4 hover:-translate-y-1 transition-all">
                        <div class="w-10 h-10 rounded-full bg-sage/10 flex items-center justify-center text-sage shrink-0">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                        <p class="text-stone text-lg">It supports <strong class="text-charcoal">meaningful programming</strong></p>
                    </div>
                    <div class="bg-white rounded-xl p-8 shadow-sm border border-stone/5 flex items-start gap-4 hover:-translate-y-1 transition-all">
                        <div class="w-10 h-10 rounded-full bg-sage/10 flex items-center justify-center text-sage shrink-0">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                        <p class="text-stone text-lg"><strong class="text-charcoal">Food, ritual, and aesthetic</strong> integrate seamlessly</p>
                    </div>
                    <div class="bg-white rounded-xl p-8 shadow-sm border border-stone/5 flex items-start gap-4 hover:-translate-y-1 transition-all">
                        <div class="w-10 h-10 rounded-full bg-sage/10 flex items-center justify-center text-sage shrink-0">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                        <p class="text-stone text-lg">It attracts <strong class="text-charcoal">thoughtful, growth-oriented guests</strong></p>
                    </div>
                    <div
                        class="bg-white rounded-xl p-8 shadow-sm border border-stone/5 flex items-start gap-4 hover:-translate-y-1 transition-all md:col-span-2"
                    >
                        <div class="w-10 h-10 rounded-full bg-sage/10 flex items-center justify-center text-sage shrink-0">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                        <p class="text-stone text-lg">It feels like a <strong class="text-charcoal">hidden sanctuary in the desert</strong></p>
                    </div>
                </div>

                <div class="text-center max-w-2xl mx-auto">
                    <p class="font-serif text-2xl text-charcoal">It is designed for atmosphere — not excess.</p>
                </div>
            </div>
        </section>

        <!-- Who We're For -->
        <section class="py-24 bg-cream">
            <div class="max-w-6xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                    <div class="rounded-2xl overflow-hidden shadow-lg">
                        <img
                            src="/img/about/tea-house-gathering.jpg"
                            alt="Intimate gathering at Himaya Garden tea house"
                            class="w-full h-full object-cover"
                        />
                    </div>
                    <div>
                        <p class="section-label mb-4">Our Community</p>
                        <h2 class="font-serif text-3xl md:text-4xl font-medium tracking-tight leading-tight text-charcoal mb-8">Who We're For</h2>
                        <p class="text-stone text-lg leading-relaxed mb-8">Himaya is for hosts who value:</p>
                        <ul class="space-y-5 mb-10">
                            <li class="flex items-start gap-3 text-stone text-lg">
                                <span class="text-sage text-xl mt-0.5">◈</span>
                                <span><strong class="text-charcoal">Depth</strong> over extravagance</span>
                            </li>
                            <li class="flex items-start gap-3 text-stone text-lg">
                                <span class="text-sage text-xl mt-0.5">◈</span>
                                <span><strong class="text-charcoal">Intention</strong> over spectacle</span>
                            </li>
                            <li class="flex items-start gap-3 text-stone text-lg">
                                <span class="text-sage text-xl mt-0.5">◈</span>
                                <span><strong class="text-charcoal">Community</strong> over crowds</span>
                            </li>
                            <li class="flex items-start gap-3 text-stone text-lg">
                                <span class="text-sage text-xl mt-0.5">◈</span>
                                <span><strong class="text-charcoal">Experience</strong> over performance</span>
                            </li>
                        </ul>
                        <div class="space-y-4 mb-8">
                            <p class="font-serif text-2xl text-charcoal">You are not looking for a ballroom.</p>
                            <p class="text-stone text-lg leading-relaxed">You are looking for something that feels grounded, beautiful, and alive.</p>
                            <p class="text-stone text-lg leading-relaxed">You care how your guests feel — not just how the photos look.</p>
                        </div>
                        <div class="bg-sage/5 rounded-xl p-6 border border-sage/20">
                            <p class="font-serif text-xl text-charcoal">If that resonates, you're in the right place.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Heritage Timeline / Values -->
        <section class="py-24 bg-cream-warm">
            <div class="max-w-6xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="text-center mb-16">
                    <p class="section-label fade-in">Our Values</p>
                    <h2 class="fade-in delay-1 font-serif text-3xl md:text-4xl font-medium tracking-tight leading-tight text-charcoal">
                        What Guides Us
                    </h2>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <div class="bg-white rounded-xl p-8 shadow-sm border border-stone/5 text-center hover:-translate-y-1 transition-all">
                        <div class="w-14 h-14 mx-auto mb-6 rounded-full bg-sage/10 flex items-center justify-center text-sage">
                            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                                >
                                </path>
                            </svg>
                        </div>
                        <h3 class="font-serif text-xl text-charcoal mb-3">Heritage</h3>
                        <p class="text-stone leading-relaxed">
                            We honor our Cebuano and Filipino roots in every detail — from the flavors on your plate to the warmth of our welcome.
                        </p>
                    </div>
                    <div class="bg-white rounded-xl p-8 shadow-sm border border-stone/5 text-center hover:-translate-y-1 transition-all">
                        <div class="w-14 h-14 mx-auto mb-6 rounded-full bg-sage/10 flex items-center justify-center text-sage">
                            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
                                >
                                </path>
                            </svg>
                        </div>
                        <h3 class="font-serif text-xl text-charcoal mb-3">Hospitality</h3>
                        <p class="text-stone leading-relaxed">
                            True hospitality is making people feel seen. We bring heart into every gathering, ensuring every guest feels genuinely
                            cared for.
                        </p>
                    </div>
                    <div class="bg-white rounded-xl p-8 shadow-sm border border-stone/5 text-center hover:-translate-y-1 transition-all">
                        <div class="w-14 h-14 mx-auto mb-6 rounded-full bg-sage/10 flex items-center justify-center text-sage">
                            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                >
                                </path>
                            </svg>
                        </div>
                        <h3 class="font-serif text-xl text-charcoal mb-3">Intention</h3>
                        <p class="text-stone leading-relaxed">
                            Every element is chosen with purpose. We believe celebrations should unfold with meaning, not just momentum.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Final CTA -->
        <section class="relative py-32 text-center text-white overflow-hidden">
            <div class="absolute inset-0 z-0">
                <img src="/img/about/garden-sunset.jpg" alt="Himaya Garden at sunset" class="w-full h-full object-cover" />
            </div>
            <div class="absolute inset-0 bg-charcoal/50 z-[1]"></div>
            <div class="relative z-[2] max-w-3xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <h2 class="fade-in font-serif text-4xl md:text-6xl font-medium tracking-tight leading-tight mb-6">Come Gather With Us</h2>
                <p class="fade-in delay-1 text-lg leading-relaxed mb-8 text-white/90">
                    Whether you're planning a celebration or simply want to experience the garden, we'd love to welcome you.
                </p>
                <div class="fade-in delay-2 flex flex-wrap gap-4 justify-center">
                    <a href="/contact" class="btn-primary bg-white text-charcoal hover:bg-charcoal hover:text-white transition-all">
                        Schedule a Tour
                    </a>
                    <a href="/venue-rates" class="btn-secondary border-white/30 text-white hover:bg-white hover:text-charcoal transition-all">
                        Explore Our Collections
                    </a>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>
