---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
    title="Upcoming Events — Himaya Garden"
    description="Discover upcoming events at Himaya Garden. From garden celebrations to intimate tea house gatherings in Tucson, Arizona."
>
    <main>
        <!-- Page Header -->
        <section class="pt-32 pb-20 bg-cream">
            <div class="max-w-6xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32 text-center">
                <p class="section-label fade-in">What's Happening</p>
                <h1 class="fade-in delay-1 font-serif text-4xl md:text-6xl lg:text-7xl font-medium tracking-tight leading-tight text-charcoal mb-6">
                    Upcoming Events
                </h1>
                <p class="fade-in delay-2 text-lg text-stone leading-relaxed max-w-2xl mx-auto mb-10">
                    From intimate tea ceremonies to garden celebrations, explore what's happening at Himaya Garden. Join us for curated gatherings,
                    workshops, and seasonal celebrations.
                </p>

                <!-- Quick Filters -->
                <div class="fade-in delay-3 flex flex-wrap justify-center gap-3">
                    <a
                        href="#calendar-view"
                        class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-sage/10 text-sage hover:bg-sage hover:text-white transition-all font-medium text-sm tracking-wide"
                    >
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                            >
                            </path>
                        </svg>
                        Full Calendar
                    </a>
                    <a
                        href="#featured-events"
                        class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-sage/10 text-sage hover:bg-sage hover:text-white transition-all font-medium text-sm tracking-wide"
                    >
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"
                            >
                            </path>
                        </svg>
                        Featured Events
                    </a>
                </div>
            </div>
        </section>

        <!-- Featured Events Section -->
        <section id="featured-events" class="py-24 bg-cream">
            <div class="max-w-6xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="text-center mb-16">
                    <p class="section-label fade-in">This Season</p>
                    <h2 class="fade-in delay-1 font-serif text-3xl md:text-5xl font-medium tracking-tight leading-tight text-charcoal">
                        Featured Gatherings
                    </h2>
                    <p class="fade-in delay-2 text-stone mt-4 max-w-2xl mx-auto text-lg leading-relaxed">
                        Curated experiences designed to bring our community together in the garden and tea house.
                    </p>
                </div>

                <!-- Featured Events Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20">
                    <!-- Event Card 1 -->
                    <article
                        class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all border border-stone/10 hover:-translate-y-1"
                    >
                        <div class="relative h-56 overflow-hidden">
                            <img
                                src="/img/events/garden-tea-party.jpg"
                                alt="Garden High Tea"
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                            />
                            <div class="absolute top-4 left-4 bg-white/95 backdrop-blur-sm rounded-xl px-4 py-2 text-center shadow-sm">
                                <p class="text-sage font-bold text-xs uppercase tracking-wider">Oct</p>
                                <p class="font-serif text-2xl text-charcoal font-medium">15</p>
                            </div>
                            <div class="absolute top-4 right-4 bg-sage text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
                                Tea House
                            </div>
                        </div>
                        <div class="p-6">
                            <h3 class="font-serif text-2xl text-charcoal mb-2 group-hover:text-sage transition-colors">Autumn Garden High Tea</h3>
                            <p class="text-stone text-sm mb-4 flex items-center gap-2">
                                <svg class="w-4 h-4 text-sage" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                    >
                                    </path>
                                </svg>
                                2:00 PM — 4:00 PM
                            </p>
                            <p class="text-stone leading-relaxed mb-6">
                                A seasonal Filipino-inspired high tea experience in the tea house. Savor warm flavors, delicate pastries, and curated
                                teas amid autumn décor.
                            </p>
                            <div class="flex items-center justify-between">
                                <span class="text-charcoal font-medium">$65 per guest</span>
                                <a href="/contact" class="inline-flex items-center gap-2 text-sage font-medium text-sm hover:gap-3 transition-all">
                                    Reserve Your Seat
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </article>

                    <!-- Event Card 2 -->
                    <article
                        class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all border border-stone/10 hover:-translate-y-1"
                    >
                        <div class="relative h-56 overflow-hidden">
                            <img
                                src="/img/events/garden-wedding-showcase.jpg"
                                alt="Wedding Showcase"
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                            />
                            <div class="absolute top-4 left-4 bg-white/95 backdrop-blur-sm rounded-xl px-4 py-2 text-center shadow-sm">
                                <p class="text-sage font-bold text-xs uppercase tracking-wider">Oct</p>
                                <p class="font-serif text-2xl text-charcoal font-medium">22</p>
                            </div>
                            <div
                                class="absolute top-4 right-4 bg-charcoal text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider"
                            >
                                Garden
                            </div>
                        </div>
                        <div class="p-6">
                            <h3 class="font-serif text-2xl text-charcoal mb-2 group-hover:text-sage transition-colors">Garden Wedding Showcase</h3>
                            <p class="text-stone text-sm mb-4 flex items-center gap-2">
                                <svg class="w-4 h-4 text-sage" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                    >
                                    </path>
                                </svg>
                                10:00 AM — 1:00 PM
                            </p>
                            <p class="text-stone leading-relaxed mb-6">
                                Tour the garden venue, meet our catering team, and envision your celebration. Complimentary tastings, décor
                                inspiration, and exclusive booking incentives included.
                            </p>
                            <div class="flex items-center justify-between">
                                <span class="text-charcoal font-medium">Complimentary</span>
                                <a href="/contact" class="inline-flex items-center gap-2 text-sage font-medium text-sm hover:gap-3 transition-all">
                                    RSVP Now
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </article>

                    <!-- Event Card 3 -->
                    <article
                        class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all border border-stone/10 hover:-translate-y-1"
                    >
                        <div class="relative h-56 overflow-hidden">
                            <img
                                src="/img/events/holiday-tea.jpg"
                                alt="Holiday Tea"
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                            />
                            <div class="absolute top-4 left-4 bg-white/95 backdrop-blur-sm rounded-xl px-4 py-2 text-center shadow-sm">
                                <p class="text-sage font-bold text-xs uppercase tracking-wider">Dec</p>
                                <p class="font-serif text-2xl text-charcoal font-medium">10</p>
                            </div>
                            <div class="absolute top-4 right-4 bg-sage text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
                                Tea House
                            </div>
                        </div>
                        <div class="p-6">
                            <h3 class="font-serif text-2xl text-charcoal mb-2 group-hover:text-sage transition-colors">
                                Holiday Wreath & Tea Workshop
                            </h3>
                            <p class="text-stone text-sm mb-4 flex items-center gap-2">
                                <svg class="w-4 h-4 text-sage" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                    >
                                    </path>
                                </svg>
                                11:00 AM — 2:00 PM
                            </p>
                            <p class="text-stone leading-relaxed mb-6">
                                Craft your own seasonal wreath while enjoying a classic high tea service. All materials, instruction, and refreshments
                                included. Limited seating.
                            </p>
                            <div class="flex items-center justify-between">
                                <span class="text-charcoal font-medium">$85 per guest</span>
                                <a href="/contact" class="inline-flex items-center gap-2 text-sage font-medium text-sm hover:gap-3 transition-all">
                                    Reserve Your Seat
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </article>
                </div>

                <!-- Event Categories -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="bg-warm-white rounded-xl p-8 text-center shadow-sm hover:-translate-y-1 transition-all border border-stone/5">
                        <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-sage/10 flex items-center justify-center text-sage">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z">
                                </path>
                            </svg>
                        </div>
                        <h3 class="font-serif text-xl text-charcoal mb-2">Tea House Experiences</h3>
                        <p class="text-stone text-sm leading-relaxed">
                            Intimate gatherings, high tea services, and workshops in our elegant tea house. Perfect for smaller groups seeking refined
                            hospitality.
                        </p>
                    </div>
                    <div class="bg-warm-white rounded-xl p-8 text-center shadow-sm hover:-translate-y-1 transition-all border border-stone/5">
                        <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-sage/10 flex items-center justify-center text-sage">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M3 21v-8a2 2 0 012-2h14a2 2 0 012 2v8M10 11V7a4 4 0 118 0v4"
                                >
                                </path>
                            </svg>
                        </div>
                        <h3 class="font-serif text-xl text-charcoal mb-2">Garden Celebrations</h3>
                        <p class="text-stone text-sm leading-relaxed">
                            Open-air events, wedding showcases, and seasonal festivals in our premier outdoor venue. Experience the beauty of Tucson's
                            garden setting.
                        </p>
                    </div>
                    <div class="bg-warm-white rounded-xl p-8 text-center shadow-sm hover:-translate-y-1 transition-all border border-stone/5">
                        <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-sage/10 flex items-center justify-center text-sage">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                                >
                                </path>
                            </svg>
                        </div>
                        <h3 class="font-serif text-xl text-charcoal mb-2">Private Bookings</h3>
                        <p class="text-stone text-sm leading-relaxed">
                            Reserve the garden or tea house for your own celebration. From bridal showers to corporate gatherings, we make private
                            events effortless.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Full Calendar Section -->
        <section id="calendar-view" class="py-24 bg-cream-warm scroll-mt-24">
            <div class="max-w-6xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="text-center mb-16">
                    <p class="section-label fade-in">Full Schedule</p>
                    <h2 class="fade-in delay-1 font-serif text-3xl md:text-5xl font-medium tracking-tight leading-tight text-charcoal">
                        Event Calendar
                    </h2>
                    <p class="fade-in delay-2 text-stone mt-4 max-w-2xl mx-auto text-lg leading-relaxed">
                        View all upcoming events, availability, and private booking openings. Subscribe to stay updated on new gatherings.
                    </p>
                </div>

                <!-- Google Calendar Embed -->
                <div class="bg-white rounded-2xl shadow-sm border border-stone/10 overflow-hidden mb-10">
                    <div class="p-4 bg-cream border-b border-stone/10 flex flex-wrap items-center justify-between gap-4">
                        <div class="flex items-center gap-3">
                            <div class="w-3 h-3 rounded-full bg-sage"></div>
                            <span class="text-sm text-stone">Tea House Events</span>
                            <div class="w-3 h-3 rounded-full bg-charcoal ml-2"></div>
                            <span class="text-sm text-stone">Garden Events</span>
                            <div class="w-3 h-3 rounded-full bg-stone ml-2"></div>
                            <span class="text-sm text-stone">Private Bookings</span>
                        </div>
                        <a
                            href="https://calendar.google.com/calendar/u/0?cid=YOUR_CALENDAR_ID"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center gap-2 text-sage font-medium text-sm hover:underline"
                        >
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                                >
                                </path>
                            </svg>
                            Open in Google Calendar
                        </a>
                    </div>
                    <div class="relative w-full" style="padding-bottom: 75%;">
                        <iframe
                            src="https://calendar.google.com/calendar/embed?src=YOUR_CALENDAR_ID&ctz=America%2FPhoenix&showTitle=0&showNav=1&showDate=1&showPrint=0&showTabs=1&showCalendars=1&showTz=1&mode=MONTH&bgcolor=%23FDFCF8&src=YOUR_SECOND_CALENDAR_ID&color=%23A3B18A&color=%23333D29&color=%23585C4E"
                            style="border: 0; position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
                            frameborder="0"
                            scrolling="no"
                            title="Himaya Garden Events Calendar"
                        >
                        </iframe>
                    </div>
                </div>

                <!-- Calendar Instructions -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
                    <div class="bg-white rounded-xl p-8 shadow-sm border border-stone/5">
                        <h3 class="font-serif text-xl text-charcoal mb-4 flex items-center gap-3">
                            <svg class="w-5 h-5 text-sage" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"
                                >
                                </path>
                            </svg>
                            Stay Notified
                        </h3>
                        <p class="text-stone leading-relaxed mb-4">
                            Never miss an event. Subscribe to our Google Calendar and receive automatic updates when new events are added or dates
                            change.
                        </p>
                        <a
                            href="https://calendar.google.com/calendar/u/0?cid=YOUR_CALENDAR_ID"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-sage/10 text-sage hover:bg-sage hover:text-white transition-all font-medium text-sm"
                        >
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                            </svg>
                            Add to My Calendar
                        </a>
                    </div>
                    <div class="bg-white rounded-xl p-8 shadow-sm border border-stone/5">
                        <h3 class="font-serif text-xl text-charcoal mb-4 flex items-center gap-3">
                            <svg class="w-5 h-5 text-sage" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                                >
                                </path>
                            </svg>
                            Host Your Own Event
                        </h3>
                        <p class="text-stone leading-relaxed mb-4">
                            Interested in a private date? Check our availability calendar and inquire about booking the garden or tea house for your
                            celebration.
                        </p>
                        <a
                            href="/contact"
                            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-sage/10 text-sage hover:bg-sage hover:text-white transition-all font-medium text-sm"
                        >
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
                                >
                                </path>
                            </svg>
                            Check Availability
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Private Events CTA -->
        <section class="py-24 bg-cream">
            <div class="max-w-6xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <div class="bg-sage/5 rounded-2xl p-10 md:p-16 text-center max-w-4xl mx-auto border border-sage/20">
                    <p class="section-label">Private Celebrations</p>
                    <h2 class="font-serif text-3xl md:text-4xl text-charcoal mt-4 mb-6">Don't See What You're Looking For?</h2>
                    <p class="text-stone text-lg leading-relaxed mb-8 max-w-2xl mx-auto">
                        Himaya Garden is available for private bookings year-round. Whether you're planning a wedding, shower, corporate event, or
                        intimate dinner, we'd love to create something beautiful together.
                    </p>
                    <div class="flex flex-wrap gap-4 justify-center">
                        <a href="/venue-rates" class="btn-primary">View Venue Rates</a>
                        <a href="/contact" class="btn-secondary">Plan Your Event</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Newsletter / Updates -->
        <section class="py-20 bg-cream-warm text-center">
            <div class="max-w-2xl mx-auto px-6">
                <p class="font-serif text-3xl md:text-4xl text-charcoal mb-3">Stay in the Loop</p>
                <p class="text-stone text-lg mb-8">Be the first to know about new events, seasonal workshops, and exclusive venue openings.</p>
                <form class="flex flex-col sm:flex-row gap-4 justify-center max-w-md mx-auto" action="/api/newsletter" method="POST">
                    <input
                        type="email"
                        name="email"
                        placeholder="Your email address"
                        required
                        class="flex-1 px-5 py-3 rounded-full border border-stone/30 bg-white focus:outline-none focus:ring-2 focus:ring-sage/50"
                    />
                    <button type="submit" class="btn-primary whitespace-nowrap px-8">Subscribe</button>
                </form>
                <p class="text-stone text-sm mt-5 italic">Join our community of garden lovers and celebration planners.</p>
            </div>
        </section>

        <!-- Final CTA -->
        <section class="relative py-32 text-center text-white overflow-hidden">
            <div class="absolute inset-0 z-0">
                <img src="/img/AG1_4.jpg" alt="Himaya Garden sunset" class="w-full h-full object-cover" />
            </div>
            <div class="absolute inset-0 bg-charcoal/50 z-[1]"></div>
            <div class="relative z-[2] max-w-3xl mx-auto px-6 md:px-12 lg:px-20 xl:px-32">
                <h2 class="fade-in font-serif text-4xl md:text-6xl font-medium tracking-tight leading-tight mb-6">Let's Celebrate Together</h2>
                <p class="fade-in delay-1 text-lg leading-relaxed mb-8 text-white/90">
                    Whether you join us for a curated event or book your own private gathering, Himaya Garden is where meaningful moments bloom.
                </p>
                <div class="fade-in delay-2 flex flex-wrap gap-4 justify-center">
                    <a href="/contact" class="btn-primary bg-white text-charcoal hover:bg-charcoal hover:text-white transition-all">
                        Schedule a Tour
                    </a>
                    <a href="tel:+15204671033" class="btn-secondary border-white/30 text-white hover:bg-white hover:text-charcoal transition-all">
                        Call (520) 467-1033
                    </a>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>

<style>
    /* Ensure iframe responsiveness */
    .calendar-wrapper iframe {
        min-height: 600px;
    }
    @media (max-width: 768px) {
        .calendar-wrapper iframe {
            min-height: 400px;
        }
    }
</style>
